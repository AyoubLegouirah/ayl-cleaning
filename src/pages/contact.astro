---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Head from '../components/Head.astro';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <Head title="Contact" description="Contactez AYL Cleaning pour un devis gratuit. Nettoyage de vitres, canapés et après travaux à Bruxelles. Réponse en 24h."/>
</head>
<body class="bg-surface text-on-surface font-body">

<Nav currentPage="contact"/>

<main class="min-h-screen">

  <!-- HERO -->
  <section class="relative pt-24 pb-16 px-8 max-w-7xl mx-auto">
    <div class="max-w-3xl">
      <span class="inline-block text-tertiary font-bold tracking-widest uppercase text-xs mb-4">Contactez-nous</span>
      <h1 class="text-5xl md:text-7xl font-headline font-extrabold text-on-surface tracking-tighter mb-8 leading-[0.9]">
        Un espace impeccable<br/><span class="text-primary">commence ici.</span>
      </h1>
      <p class="text-on-surface-variant text-lg md:text-xl max-w-xl leading-relaxed">
        Particulier ou professionnel, notre équipe basée à Bruxelles est prête à intervenir rapidement. Devis gratuit sous 24h.
      </p>
    </div>
  </section>

  <!-- CONTACT GRID -->
  <section class="px-8 pb-32 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

      <!-- Formulaire -->
      <div class="lg:col-span-7 bg-surface-container-lowest rounded-xl p-8 md:p-12 shadow-[0_4px_48px_rgba(26,28,30,0.06)]">
        <h2 class="text-2xl font-headline font-bold mb-8">Demande de devis</h2>
        <form class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="text-xs font-bold text-on-surface-variant uppercase tracking-wider ml-1">Nom</label>
              <input id="form-nom" class="w-full bg-surface-container focus:ring-2 focus:ring-primary/30 rounded-xl py-4 px-5 text-on-surface placeholder:text-on-surface-variant/50 transition-all outline-none" placeholder="Votre nom" type="text"/>
              <p id="err-nom" class="hidden text-red-500 text-xs ml-1"></p>
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-on-surface-variant uppercase tracking-wider ml-1">Téléphone</label>
              <input id="form-tel" class="w-full bg-surface-container focus:ring-2 focus:ring-primary/30 rounded-xl py-4 px-5 text-on-surface placeholder:text-on-surface-variant/50 transition-all outline-none" placeholder="04XX XX XX XX" type="tel"/>
              <p id="err-tel" class="hidden text-red-500 text-xs ml-1"></p>
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-on-surface-variant uppercase tracking-wider ml-1">Service souhaité</label>
            <select id="form-service" class="w-full bg-surface-container focus:ring-2 focus:ring-primary/30 rounded-xl py-4 px-5 text-on-surface transition-all outline-none">
              <option value="">Choisir un service</option>
              <option>Nettoyage de vitres</option>
              <option>Nettoyage de canapés</option>
              <option>Plusieurs services</option>
            </select>
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-on-surface-variant uppercase tracking-wider ml-1">Message</label>
            <textarea id="form-message" class="w-full bg-surface-container focus:ring-2 focus:ring-primary/30 rounded-xl py-4 px-5 text-on-surface placeholder:text-on-surface-variant/50 transition-all resize-none outline-none" placeholder="Décrivez votre besoin, surface approximative, commune..." rows="5"></textarea>
          </div>
          <button id="form-submit" type="button" class="w-full md:w-auto bg-gradient-to-br from-primary to-[#004d7a] text-on-primary px-10 py-4 rounded-full font-headline font-extrabold uppercase tracking-tighter text-sm hover:shadow-[0_4px_24px_rgba(0,99,155,0.25)] transition-all duration-200 text-center cursor-pointer">
            Envoyer via WhatsApp
          </button>
        </form>
      </div>

      <!-- Infos contact -->
      <div class="lg:col-span-5 flex flex-col gap-6">

        <!-- WhatsApp CTA -->
        <div class="bg-primary/5 rounded-xl p-8 group hover:bg-primary/10 transition-all duration-300 flex items-center justify-between">
          <div>
            <h3 class="text-primary font-headline font-bold text-xl mb-1">Réponse instantanée</h3>
            <p class="text-on-surface-variant text-sm mb-6">Temps de réponse : moins de 5 minutes</p>
            <a class="inline-flex items-center gap-3 bg-[#25D366] text-white px-6 py-3 rounded-lg font-headline font-bold hover:scale-105 transition-transform" href="https://wa.me/32488338952" target="_blank">
              <span class="material-symbols-outlined">chat</span>
              Chat WhatsApp
            </a>
          </div>
          <div class="hidden md:block">
            <span class="material-symbols-outlined text-primary text-6xl opacity-20 group-hover:opacity-40 transition-opacity" style="font-variation-settings: 'FILL' 1;">phone_iphone</span>
          </div>
        </div>

        <!-- Téléphone -->
        <div class="bg-surface-container rounded-xl p-8">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center">
              <span class="material-symbols-outlined text-primary text-xl">call</span>
            </div>
            <span class="text-xs font-bold text-on-surface-variant uppercase tracking-widest">Téléphone</span>
          </div>
          <a href="tel:+32488338952" class="text-xl font-headline font-bold text-on-surface hover:text-primary transition-colors duration-200">
            +32 488 33 89 52
          </a>
        </div>

        <!-- Zone -->
        <div class="bg-surface-container rounded-xl p-8">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center">
              <span class="material-symbols-outlined text-primary text-xl">location_on</span>
            </div>
            <span class="text-xs font-bold text-on-surface-variant uppercase tracking-widest">Zone d'intervention</span>
          </div>
          <p class="text-xl font-headline font-bold text-on-surface">Bruxelles & environs</p>
          <p class="text-on-surface-variant text-sm mt-2">Anderlecht, Ixelles, Uccle, Forest, Schaerbeek, Molenbeek, Saint-Gilles, Etterbeek, Laeken et plus.</p>
        </div>

        <!-- Horaires -->
        <div class="bg-surface-container rounded-xl p-8">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center">
              <span class="material-symbols-outlined text-primary text-xl">schedule</span>
            </div>
            <span class="text-xs font-bold text-on-surface-variant uppercase tracking-widest">Horaires</span>
          </div>
          <p class="text-xl font-headline font-bold text-on-surface">7j/7</p>
          <p class="text-on-surface-variant text-sm mt-2">Lundi – Dimanche, 09:00 – 17:00</p>
        </div>

      </div>
    </div>
  </section>

  <!-- IMAGE BREAK -->
  <section class="px-8 pb-32 max-w-7xl mx-auto">
    <div class="relative h-[400px] rounded-2xl overflow-hidden">
      <img alt="Intérieur luxueux propre à Bruxelles" class="w-full h-full object-cover" src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=1400&q=80"/>
      <div class="absolute inset-0 bg-gradient-to-t from-white/80 via-white/20 to-transparent"></div>
      <div class="absolute bottom-12 left-12 max-w-lg">
        <h3 class="text-3xl font-headline font-extrabold text-on-surface mb-2">Votre espace, notre priorité.</h3>
        <p class="text-on-surface-variant">Nos professionnels interviennent avec précision et discrétion dans tous types d'espaces.</p>
      </div>
    </div>
  </section>

</main>

<Footer/>

<script is:inline>
  document.getElementById('form-submit').addEventListener('click', function () {
    const nom = document.getElementById('form-nom').value.trim();
    const tel = document.getElementById('form-tel').value.trim();
    const service = document.getElementById('form-service').value;
    const message = document.getElementById('form-message').value.trim();

    const errNom = document.getElementById('err-nom');
    const errTel = document.getElementById('err-tel');
    let valid = true;

    if (!nom) {
      errNom.textContent = 'Veuillez entrer votre nom.';
      errNom.classList.remove('hidden');
      valid = false;
    } else {
      errNom.classList.add('hidden');
    }

    if (!tel) {
      errTel.textContent = 'Veuillez entrer votre numéro de téléphone.';
      errTel.classList.remove('hidden');
      valid = false;
    } else {
      errTel.classList.add('hidden');
    }

    if (!valid) return;

    const text =
      'Bonjour AYL Cleaning 👋\n\n' +
      'Nom : ' + nom + '\n' +
      'Téléphone : ' + tel + '\n' +
      'Service : ' + (service || 'Non précisé') + '\n\n' +
      'Message : ' + (message || 'Aucun message');

    window.open('https://wa.me/32488338952?text=' + encodeURIComponent(text), '_blank');
  });
</script>

</body>
</html>