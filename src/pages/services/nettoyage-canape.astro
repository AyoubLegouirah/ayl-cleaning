---
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Head from '../../components/Head.astro';
---

<!DOCTYPE html>
<html class="dark" lang="fr">
<head>
  <Head
    title="Nettoyage de canapé à Bruxelles — AYL Cleaning"
    description="Nettoyage professionnel de canapés à Bruxelles. Extraction en profondeur, séchage rapide, produits écologiques. Intervention chez vous 7j/7. Devis gratuit en 24h — 0488 33 89 52."
  />
</head>
<body class="bg-surface text-on-surface font-body">

<Nav currentPage="services"/>

<main>

  <!-- HERO -->
  <section class="relative pt-32 pb-20 px-8 max-w-7xl mx-auto">
    <span class="text-primary uppercase tracking-[0.2em] text-xs font-bold mb-4 block">
      🛋️ Nettoyage de canapés
    </span>
    <h1 class="font-headline text-5xl md:text-6xl font-extrabold text-on-surface leading-tight max-w-3xl mb-6 tracking-tighter">
      Nettoyage de canapé<br/>
      <span class="text-primary">à Bruxelles</span>
    </h1>
    <p class="text-on-surface-variant text-lg max-w-2xl leading-relaxed mb-10">
      Votre canapé accumule poussières, acariens, taches et odeurs au fil du temps. AYL Cleaning intervient à domicile à Bruxelles et communes environnantes pour un nettoyage en profondeur, avec séchage rapide et résultat garanti.
    </p>
    <div class="flex gap-4 flex-wrap">
      <a href="/contact" class="bg-primary text-on-primary px-8 py-4 rounded-md font-headline font-bold hover:bg-primary-container transition-all">
        Devis gratuit
      </a>
      <a href="https://wa.me/32488338952" target="_blank" class="border border-[#414751]/30 px-8 py-4 rounded-md font-headline font-bold hover:border-primary transition-all">
        💚 WhatsApp
      </a>
      <a href="tel:+32488338952" class="border border-[#414751]/30 px-8 py-4 rounded-md font-headline font-bold hover:border-primary transition-all">
        📞 0488 33 89 52
      </a>
    </div>
  </section>

  <!-- AVANTAGES -->
  <section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-surface-container rounded-xl p-8 border border-[#414751]/10">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">verified</span>
          <h3 class="font-headline font-bold text-lg mb-3">Résultat garanti</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Pas satisfait ? On revient sans frais. Votre satisfaction est notre priorité absolue.</p>
        </div>
        <div class="bg-surface-container rounded-xl p-8 border border-[#414751]/10">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">speed</span>
          <h3 class="font-headline font-bold text-lg mb-3">Séchage rapide</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Technique d'extraction à faible humidité. Votre canapé est sec en 2 à 4 heures.</p>
        </div>
        <div class="bg-surface-container rounded-xl p-8 border border-[#414751]/10">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">eco</span>
          <h3 class="font-headline font-bold text-lg mb-3">Produits écologiques</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Produits professionnels sans danger pour vos enfants et vos animaux de compagnie.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTENU SEO — Ce qu'on nettoie -->
  <section class="py-24 px-8 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
      <div>
        <h2 class="font-headline text-3xl font-extrabold mb-6 tracking-tighter">
          Pourquoi faire nettoyer<br/><span class="text-primary">votre canapé ?</span>
        </h2>
        <p class="text-on-surface-variant leading-relaxed mb-4">
          Un canapé utilisé quotidiennement accumule en moyenne <strong class="text-on-surface">des millions d'acariens</strong>, des allergènes, des odeurs de transpiration et des taches difficiles à éliminer avec un simple aspirateur.
        </p>
        <p class="text-on-surface-variant leading-relaxed mb-4">
          Le nettoyage professionnel va en profondeur dans les fibres du tissu, là où les produits ménagers ne pénètrent pas. Résultat : un canapé propre, désinfecté et qui retrouve ses couleurs d'origine.
        </p>
        <p class="text-on-surface-variant leading-relaxed">
          Nous recommandons un nettoyage tous les 12 à 18 mois pour les foyers avec enfants ou animaux, et tous les 2 ans pour les autres.
        </p>
      </div>
      <div class="space-y-4">
        <h3 class="font-headline font-bold text-xl mb-4">Ce qu'on traite :</h3>
        {[
          { icon: "chair", label: "Canapés tissu, microfibre, velours" },
          { icon: "weekend", label: "Canapés cuir et similicuir" },
          { icon: "event_seat", label: "Fauteuils et poufs" },
          { icon: "airline_seat_recline_normal", label: "Sièges de bureau et chaises" },
          { icon: "bed", label: "Têtes de lit et matelas" },
          { icon: "local_laundry_service", label: "Taches tenaces (vin, café, urine, sang)" },
        ].map(item => (
          <div class="flex items-center gap-4 bg-surface-container rounded-xl px-6 py-4 border border-[#414751]/10">
            <span class="material-symbols-outlined text-primary">{item.icon}</span>
            <span class="text-on-surface-variant text-sm">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESSUS -->
  <section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-headline text-3xl font-extrabold mb-12 tracking-tighter text-center">
        Comment se passe <span class="text-primary">l'intervention ?</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        {[
          { step: "01", icon: "phone_in_talk", title: "Devis gratuit", desc: "Contactez-nous par téléphone ou WhatsApp. Réponse sous 24h avec un prix fixe, sans surprise." },
          { step: "02", icon: "calendar_month", title: "Rendez-vous", desc: "On fixe un créneau à votre convenance, en semaine ou le week-end, de 9h à 17h." },
          { step: "03", icon: "cleaning_services", title: "Nettoyage à domicile", desc: "Notre technicien se déplace chez vous avec tout le matériel. Durée : 45 min à 1h30 selon la taille." },
          { step: "04", icon: "check_circle", title: "Résultat immédiat", desc: "Votre canapé est propre, désinfecté et sec en 2 à 4 heures. Résultat visible immédiatement." },
        ].map(item => (
          <div class="relative bg-surface-container rounded-xl p-8 border border-[#414751]/10">
            <span class="text-primary/20 font-headline font-extrabold text-6xl absolute top-4 right-6">{item.step}</span>
            <span class="material-symbols-outlined text-primary text-3xl mb-4 block">{item.icon}</span>
            <h3 class="font-headline font-bold text-lg mb-3">{item.title}</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TARIFS -->
  <section class="py-24 px-8 max-w-7xl mx-auto">
    <h2 class="font-headline text-3xl font-extrabold mb-4 tracking-tighter">
      Tarifs indicatifs —<span class="text-primary"> Nettoyage canapé</span>
    </h2>
    <p class="text-on-surface-variant mb-10">Prix indicatifs pour Bruxelles et communes. Devis gratuit et personnalisé sur demande.</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {[
        { label: "Canapé 2 places", price: "60–80€", desc: "Tissu ou microfibre, nettoyage complet coussinets inclus" },
        { label: "Canapé 3 places", price: "80–110€", desc: "Tissu, velours ou similicuir, traitement anti-acariens inclus" },
        { label: "Canapé d'angle", price: "120–160€", desc: "Grand format, méridienne incluse, séchage rapide garanti" },
      ].map(item => (
        <div class="bg-surface-container rounded-xl p-8 border border-[#414751]/10 flex flex-col gap-3">
          <h3 class="font-headline font-bold text-lg">{item.label}</h3>
          <p class="text-primary font-headline font-extrabold text-3xl">{item.price}</p>
          <p class="text-on-surface-variant text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
    <p class="text-on-surface-variant/60 text-xs mt-6">* Prix indicatifs hors déplacement. Tarif exact confirmé après évaluation. Déplacement gratuit dans un rayon de 20km autour de Bruxelles.</p>
  </section>

  <!-- FAQ -->
  <section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-headline text-3xl font-extrabold mb-12 tracking-tighter">
        Questions fréquentes —<span class="text-primary"> Nettoyage canapé</span>
      </h2>
      <div class="space-y-4">
        {[
          {
            q: "Combien de temps faut-il pour que le canapé sèche ?",
            a: "Entre 2 et 4 heures selon le tissu et la ventilation de la pièce. Nous utilisons une technique à faible humidité qui accélère le séchage. Vous pouvez réutiliser votre canapé le jour même."
          },
          {
            q: "Vous vous déplacez à domicile à Bruxelles ?",
            a: "Oui, nous intervenons exclusivement à domicile dans toutes les communes de Bruxelles (Anderlecht, Ixelles, Uccle, Schaerbeek, Etterbeek, Forest, Molenbeek, Saint-Gilles, Laeken…) et dans un rayon de 20km autour de Bruxelles."
          },
          {
            q: "Les produits utilisés sont-ils sans danger pour mes enfants et animaux ?",
            a: "Absolument. Nous utilisons uniquement des produits professionnels homologués, biodégradables et sans résidus toxiques. Votre famille peut utiliser le canapé dès qu'il est sec."
          },
          {
            q: "Pouvez-vous éliminer les taches d'urine ou d'animaux ?",
            a: "Oui, nous traitons les taches d'urine, de sang, de café, de vin et les odeurs d'animaux avec des produits enzymatiques spécialisés. Mentionnez-le lors de votre demande de devis pour qu'on adapte le traitement."
          },
          {
            q: "Comment obtenir un devis ?",
            a: "Appelez-nous au 0488 33 89 52 ou envoyez-nous un message WhatsApp avec une photo de votre canapé. Nous vous répondons sous 24h avec un prix fixe et sans surprise."
          },
        ].map((item, i) => (
          <details class="bg-surface-container rounded-xl border border-[#414751]/10 group">
            <summary class="px-8 py-6 font-headline font-bold cursor-pointer flex justify-between items-center list-none">
              <span>{item.q}</span>
              <span class="material-symbols-outlined text-primary group-open:rotate-180 transition-transform">expand_more</span>
            </summary>
            <p class="px-8 pb-6 text-on-surface-variant text-sm leading-relaxed">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ZONES -->
  <section class="py-24 px-8 max-w-7xl mx-auto">
    <h2 class="font-headline text-3xl font-extrabold mb-4 tracking-tighter">
      Zones d'intervention — <span class="text-primary">Canapé Bruxelles</span>
    </h2>
    <p class="text-on-surface-variant mb-8">Nous intervenons dans toutes les communes de Bruxelles :</p>
    <div class="flex flex-wrap gap-3">
      {[
        { slug: 'bruxelles', label: 'Bruxelles' },
        { slug: 'anderlecht', label: 'Anderlecht' },
        { slug: 'ixelles', label: 'Ixelles' },
        { slug: 'uccle', label: 'Uccle' },
        { slug: 'etterbeek', label: 'Etterbeek' },
        { slug: 'forest', label: 'Forest' },
        { slug: 'schaerbeek', label: 'Schaerbeek' },
        { slug: 'molenbeek', label: 'Molenbeek' },
        { slug: 'saint-gilles', label: 'Saint-Gilles' },
        { slug: 'laeken', label: 'Laeken' },
      ].map(c => (
        <a href={`/zones/${c.slug}/nettoyage-canape`} class="bg-surface-container border border-[#414751]/10 px-4 py-2 rounded-full text-sm hover:border-primary hover:text-primary transition-all">
          📍 {c.label}
        </a>
      ))}
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="py-24 px-8">
    <div class="max-w-4xl mx-auto bg-gradient-to-br from-surface-container to-surface-container-low rounded-3xl p-16 text-center border border-[#414751]/10">
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold mb-4 tracking-tighter">
        Votre canapé mérite<br/><span class="text-primary">un nettoyage professionnel</span>
      </h2>
      <p class="text-on-surface-variant text-lg mb-10 max-w-xl mx-auto">
        Devis gratuit en 24h. Intervention à domicile à Bruxelles 7j/7. Résultat garanti ou on revient sans frais.
      </p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="/contact" class="bg-primary text-on-primary px-10 py-4 rounded-md font-headline font-bold hover:bg-primary-container transition-all">
          Demander un devis gratuit
        </a>
        <a href="https://wa.me/32488338952" target="_blank" class="border border-[#414751]/30 px-10 py-4 rounded-md font-headline font-bold hover:border-primary transition-all">
          💚 WhatsApp
        </a>
        <a href="tel:+32488338952" class="border border-[#414751]/30 px-10 py-4 rounded-md font-headline font-bold hover:border-primary transition-all">
          📞 0488 33 89 52
        </a>
      </div>
    </div>
  </section>

</main>

<Footer/>

</body>
</html>