---
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Head from '../../components/Head.astro';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <Head
    title="Services Nettoyage Bruxelles — AYL Cleaning"
    description="Nettoyage de canapés et vitres à Bruxelles. Intervention à domicile pour particuliers et professionnels. Devis gratuit en 24h — +32 488 33 89 52."
    canonical="/services"
  />
</head>
<body class="bg-surface text-on-surface font-body">

<Nav currentPage="services"/>

<main>
  <!-- HERO -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="max-w-7xl mx-auto px-8 relative z-10">
      <span class="text-primary uppercase tracking-[0.2em] text-xs font-bold mb-4 block">Nos expertises</span>
      <h1 class="font-headline text-5xl md:text-7xl font-extrabold text-on-surface leading-[1.1] max-w-3xl mb-8 tracking-tighter">
        Nettoyage professionnel pour des espaces <span class="text-primary italic">impeccables.</span>
      </h1>
      <p class="text-on-surface-variant text-lg max-w-xl leading-relaxed">
        Spécialistes du nettoyage à Bruxelles. Nous intervenons chez les particuliers et les professionnels avec précision et discrétion.
      </p>
    </div>
    <div class="absolute top-0 right-0 w-2/3 h-full opacity-20 pointer-events-none bg-gradient-to-l from-primary-container/20 to-transparent"></div>
  </section>

  <!-- SERVICES GRID -->
    <section class="max-w-7xl mx-auto px-8 py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Nettoyage canapés EN PREMIER -->
        <div class="bg-surface-container-lowest rounded-xl overflow-hidden group hover:shadow-[0_8px_48px_rgba(26,28,30,0.08)] transition-all duration-500 shadow-[0_4px_48px_rgba(26,28,30,0.04)] flex flex-col">
        <div class="h-64 overflow-hidden">
            <img alt="Nettoyage canapé Bruxelles" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" src="https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=600&q=80"/>
        </div>
        <div class="p-10 flex-grow flex flex-col justify-between">
            <div>
            <div class="flex items-center gap-3 mb-6">
                <span class="material-symbols-outlined text-primary text-3xl">chair</span>
                <h2 class="font-headline text-2xl font-bold text-on-surface">Nettoyage de canapés</h2>
            </div>
            <p class="text-on-surface-variant mb-8 leading-relaxed">Extraction en profondeur et traitement vapeur pour tous types de tissus. Séchage rapide garanti.</p>
            <ul class="space-y-3 mb-10">
                <li class="flex items-center gap-3 text-sm font-medium text-on-surface-variant">
                <span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                Désinfection certifiée éco
                </li>
                <li class="flex items-center gap-3 text-sm font-medium text-on-surface-variant">
                <span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                Technologie anti-taches
                </li>
            </ul>
            </div>
            <div class="flex gap-3">
            <a href="/services/nettoyage-canape" class="flex-1 bg-surface-container text-on-surface px-4 py-3 rounded-full hover:bg-surface-container-highest transition-all duration-200 font-bold text-sm text-center">Nettoyage canapé →</a>
            <a href="/contact" class="flex-1 bg-gradient-to-br from-primary to-[#004d7a] text-on-primary px-4 py-3 rounded-full font-bold text-sm text-center hover:shadow-[0_4px_16px_rgba(0,99,155,0.2)] transition-all duration-200">Devis gratuit</a>
            </div>
        </div>
        </div>

        <!-- Nettoyage vitres EN SECOND -->
        <div class="bg-surface-container-lowest rounded-xl overflow-hidden group hover:shadow-[0_8px_48px_rgba(26,28,30,0.08)] transition-all duration-500 shadow-[0_4px_48px_rgba(26,28,30,0.04)] flex flex-col">
        <div class="h-64 overflow-hidden">
            <img alt="Nettoyage de vitres Bruxelles" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800&q=80"/>
        </div>
        <div class="p-10 flex-grow flex flex-col justify-between">
            <div>
            <div class="flex items-center gap-3 mb-6">
                <span class="material-symbols-outlined text-primary text-3xl">window</span>
                <h2 class="font-headline text-2xl font-bold text-on-surface">Nettoyage de vitres</h2>
            </div>
            <p class="text-on-surface-variant mb-8 leading-relaxed">Fenêtres, baies vitrées, vérandas et vitrines. Résultat sans traces garanti, intérieur et extérieur.</p>
            <ul class="space-y-3 mb-10">
                <li class="flex items-center gap-3 text-sm font-medium text-on-surface-variant">
                <span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                Châssis et encadrements inclus
                </li>
                <li class="flex items-center gap-3 text-sm font-medium text-on-surface-variant">
                <span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                Matériel professionnel hauteur
                </li>
            </ul>
            </div>
            <div class="flex gap-3">
            <a href="/services/nettoyage-vitres" class="flex-1 bg-surface-container text-on-surface px-4 py-3 rounded-full hover:bg-surface-container-highest transition-all duration-200 font-bold text-sm text-center">Nettoyage vitres →</a>
            <a href="/contact" class="flex-1 bg-gradient-to-br from-primary to-[#004d7a] text-on-primary px-4 py-3 rounded-full font-bold text-sm text-center hover:shadow-[0_4px_16px_rgba(0,99,155,0.2)] transition-all duration-200">Devis gratuit</a>
            </div>
        </div>
        </div>

    </div>
    </section>

  <!-- CTA -->
  <section class="max-w-7xl mx-auto px-8 py-32 text-center">
    <div class="bg-gradient-to-br from-primary to-[#004d7a] p-16 rounded-3xl relative overflow-hidden shadow-[0_8px_48px_rgba(0,99,155,0.18)]">
      <div class="relative z-10">
        <h2 class="font-headline text-4xl md:text-5xl font-black mb-6 tracking-tighter text-on-primary" style="letter-spacing: -0.02em;">Prêt pour un espace <span class="opacity-90">impeccable ?</span></h2>
        <p class="text-on-primary/80 max-w-2xl mx-auto mb-10 text-lg">Contactez AYL Cleaning pour un devis gratuit sous 24h. Bruxelles et communes environnantes.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/contact" class="bg-white text-primary px-10 py-4 rounded-full font-bold transition-all duration-200 hover:scale-105">Demander un devis</a>
          <a href="https://wa.me/32488338952" target="_blank" class="bg-[#25D366] text-white px-10 py-4 rounded-full font-bold hover:opacity-90 transition-opacity duration-200">💚 WhatsApp</a>
        </div>
      </div>
    </div>
  </section>
</main>

<Footer/>

</body>
</html>