---
<!DOCTYPE html>
<html class="dark" lang="fr">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Nos Services | AYL Cleaning Bruxelles</title>
<meta name="description" content="Nettoyage de vitres, canapés, après travaux et bureaux à Bruxelles. Services professionnels pour particuliers et entreprises."/>
<script is:inline src="https://cdn.tailwindcss.com/3.4.1"></script>
<script is:inline>
  tailwind.config = {
    darkMode: "class",
    theme: {
      extend: {
        colors: {
          "surface": "#0f131c",
          "primary": "#a1c9ff",
          "on-primary": "#00325a",
          "primary-container": "#4494e7",
          "on-primary-container": "#002b4f",
          "secondary": "#aec8ee",
          "secondary-container": "#314a6a",
          "tertiary": "#ffb86f",
          "on-surface": "#dfe2ee",
          "on-surface-variant": "#c0c7d3",
          "surface-container": "#1c2028",
          "surface-container-low": "#181c24",
          "surface-container-high": "#262a33",
          "surface-container-highest": "#31353e",
          "surface-container-lowest": "#0a0e16",
          "outline-variant": "#414751",
        },
        fontFamily: {
          "headline": ["Manrope"],
          "body": ["Inter"],
        },
        borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem"},
      },
    },
  }
</script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<style is:inline>
  .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
</style>
</head>
<body class="bg-surface text-on-surface font-body">

<!-- NAV -->
<nav class="bg-[#0f131c]/70 backdrop-blur-3xl font-headline font-bold tracking-tight sticky top-0 z-50 border-b border-[#414751]/10">
  <div class="flex justify-between items-center w-full px-8 py-4 max-w-7xl mx-auto">
    <a href="/" class="text-2xl font-black text-[#a1c9ff] tracking-tighter">AYL</a>
    <div class="hidden md:flex gap-8 items-center">
      <a class="text-[#dfe2ee]/80 hover:text-[#a1c9ff] transition-colors" href="/">Accueil</a>
      <a class="text-[#a1c9ff] border-b-2 border-[#a1c9ff] pb-1" href="/services">Services</a>
      <a class="text-[#dfe2ee]/80 hover:text-[#a1c9ff] transition-colors" href="/contact">Contact</a>
    </div>
    <a href="/contact" class="bg-gradient-to-br from-primary to-primary-container text-on-primary px-6 py-2.5 rounded-md font-bold text-sm transition-all hover:shadow-[0_0_20px_rgba(161,201,255,0.3)]">
      Devis gratuit
    </a>
  </div>
</nav>

<main>
  <!-- HERO -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="max-w-7xl mx-auto px-8 relative z-10">
      <span class="text-primary uppercase tracking-[0.2em] text-xs font-bold mb-4 block">Nos expertises</span>
      <h1 class="font-headline text-5xl md:text-7xl font-extrabold text-on-surface leading-[1.1] max-w-3xl mb-8 tracking-tighter">
        Nettoyage professionnel pour des espaces <span class="text-primary italic">impeccables.</span>
      </h1>
      <p class="text-on-surface-variant text-lg max-w-xl leading-relaxed">
        Spécialistes du nettoyage à Bruxelles. Nous intervenons chez les particuliers et les professionnels avec précision et discrétion.
      </p>
    </div>
    <div class="absolute top-0 right-0 w-2/3 h-full opacity-20 pointer-events-none bg-gradient-to-l from-primary-container/20 to-transparent"></div>
  </section>

  <!-- SERVICES GRID -->
  <section class="max-w-7xl mx-auto px-8 py-20">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">

      <!-- Nettoyage vitres (Large) -->
      <div class="md:col-span-8 bg-surface-container rounded-xl overflow-hidden group hover:bg-surface-container-high transition-all duration-500 border border-outline-variant/10">
        <div class="flex flex-col md:flex-row h-full">
          <div class="md:w-1/2 overflow-hidden h-64 md:h-auto">
            <img alt="Nettoyage de vitres Bruxelles" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800&q=80"/>
          </div>
          <div class="md:w-1/2 p-10 flex flex-col justify-between">
            <div>
              <div class="flex items-center gap-3 mb-6">
                <span class="material-symbols-outlined text-primary text-3xl">window</span>
                <h2 class="font-headline text-2xl font-bold">Nettoyage de vitres</h2>
              </div>
              <p class="text-on-surface-variant mb-8 leading-relaxed">Fenêtres, baies vitrées, vérandas et vitrines. Résultat sans traces garanti, intérieur et extérieur.</p>
              <ul class="space-y-3 mb-10">
                <li class="flex items-center gap-3 text-sm font-medium">
                  <span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  Châssis et encadrements inclus
                </li>
                <li class="flex items-center gap-3 text-sm font-medium">
                  <span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  Matériel professionnel hauteur
                </li>
              </ul>
            </div>
            <a href="/contact" class="w-fit border border-outline-variant/30 px-8 py-3 rounded-md hover:bg-primary hover:text-on-primary hover:border-primary transition-all font-bold text-sm">
              Demander un devis
            </a>
          </div>
        </div>
      </div>

      <!-- Nettoyage canapés -->
      <div class="md:col-span-4 bg-surface-container rounded-xl overflow-hidden group hover:bg-surface-container-high transition-all duration-500 border border-outline-variant/10 flex flex-col">
        <div class="h-64 overflow-hidden">
          <img alt="Nettoyage canapé Bruxelles" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            src="https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=600&q=80"/>
        </div>
        <div class="p-10 flex-grow flex flex-col justify-between">
          <div>
            <div class="flex items-center gap-3 mb-6">
              <span class="material-symbols-outlined text-primary text-3xl">chair</span>
              <h2 class="font-headline text-2xl font-bold">Nettoyage de canapés</h2>
            </div>
            <p class="text-on-surface-variant mb-8 leading-relaxed">Extraction en profondeur et traitement vapeur pour tous types de tissus. Séchage rapide garanti.</p>
            <ul class="space-y-3 mb-10">
              <li class="flex items-center gap-3 text-sm font-medium">
                <span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                Désinfection certifiée éco
              </li>
              <li class="flex items-center gap-3 text-sm font-medium">
                <span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                Technologie anti-taches
              </li>
            </ul>
          </div>
          <a href="/contact" class="w-full border border-outline-variant/30 px-8 py-3 rounded-md hover:bg-primary hover:text-on-primary hover:border-primary transition-all font-bold text-sm text-center">
            Demander un devis
          </a>
        </div>
      </div>

      <!-- Nettoyage après travaux -->
      <div class="md:col-span-12 bg-surface-container-lowest border border-outline-variant/10 rounded-xl overflow-hidden group hover:bg-surface-container transition-all duration-500">
        <div class="grid md:grid-cols-2 items-center">
          <div class="p-12 md:p-16 order-2 md:order-1">
            <div class="flex items-center gap-3 mb-6">
              <span class="material-symbols-outlined text-primary text-4xl">construction</span>
              <h2 class="font-headline text-3xl font-extrabold tracking-tight">Nettoyage après travaux</h2>
            </div>
            <p class="text-on-surface-variant mb-10 text-lg leading-relaxed max-w-xl">Remise en état complète après chantier ou rénovation. Évacuation des poussières, nettoyage des surfaces, locaux prêts à l'usage.</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-12">
              <div class="bg-surface-container-high/40 p-4 rounded-lg border border-outline-variant/5">
                <h4 class="font-bold text-primary mb-2">Dépoussiérage HEPA</h4>
                <p class="text-xs text-on-surface-variant">Filtration industrielle pour une qualité d'air optimale.</p>
              </div>
              <div class="bg-surface-container-high/40 p-4 rounded-lg border border-outline-variant/5">
                <h4 class="font-bold text-primary mb-2">Finition détaillée</h4>
                <p class="text-xs text-on-surface-variant">Polissage de toutes les surfaces, prises et interrupteurs.</p>
              </div>
            </div>
            <a href="/contact" class="inline-block bg-primary text-on-primary px-10 py-4 rounded-md font-bold transition-all hover:shadow-[0_0_30px_rgba(161,201,255,0.2)]">
              Planifier une intervention
            </a>
          </div>
          <div class="h-full min-h-[400px] relative order-1 md:order-2 overflow-hidden">
            <img alt="Nettoyage après chantier Bruxelles" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-[2s]"
              src="https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=800&q=80"/>
            <div class="absolute inset-0 bg-gradient-to-r from-surface-container-lowest to-transparent md:block hidden"></div>
          </div>
        </div>
      </div>

      <!-- Nettoyage bureaux -->
      <div class="md:col-span-12 bg-surface-container rounded-xl overflow-hidden group hover:bg-surface-container-high transition-all duration-500 border border-outline-variant/10">
        <div class="flex flex-col md:flex-row h-full">
          <div class="md:w-1/2 overflow-hidden h-64 md:h-auto">
            <img alt="Nettoyage bureaux Bruxelles" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=800&q=80"/>
          </div>
          <div class="md:w-1/2 p-10 flex flex-col justify-between">
            <div>
              <div class="flex items-center gap-3 mb-6">
                <span class="material-symbols-outlined text-primary text-3xl">business</span>
                <h2 class="font-headline text-2xl font-bold">Nettoyage de bureaux</h2>
              </div>
              <p class="text-on-surface-variant mb-8 leading-relaxed">Locaux professionnels, open spaces, salles de réunion. Interventions régulières ou ponctuelles selon vos besoins.</p>
              <ul class="space-y-3 mb-10">
                <li class="flex items-center gap-3 text-sm font-medium">
                  <span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  Contrats réguliers disponibles
                </li>
                <li class="flex items-center gap-3 text-sm font-medium">
                  <span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  Intervention hors heures de bureau
                </li>
              </ul>
            </div>
            <a href="/contact" class="w-fit border border-outline-variant/30 px-8 py-3 rounded-md hover:bg-primary hover:text-on-primary hover:border-primary transition-all font-bold text-sm">
              Demander un devis
            </a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-7xl mx-auto px-8 py-32 text-center">
    <div class="bg-gradient-to-tr from-surface-container-low to-surface-container p-16 rounded-3xl border border-outline-variant/10 relative overflow-hidden">
      <div class="relative z-10">
        <h2 class="font-headline text-4xl md:text-5xl font-black mb-6 tracking-tighter">Prêt pour un espace <span class="text-primary">impeccable ?</span></h2>
        <p class="text-on-surface-variant max-w-2xl mx-auto mb-10 text-lg">Contactez AYL Cleaning pour un devis gratuit sous 24h. Bruxelles et communes environnantes.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/contact" class="bg-primary text-on-primary px-10 py-4 rounded-md font-bold transition-all hover:scale-105">Demander un devis</a>
          <a href="https://wa.me/32488338952" target="_blank" class="bg-surface-container-highest/50 px-10 py-4 rounded-md font-bold border border-outline-variant/20 hover:border-primary/50 transition-all">💚 WhatsApp</a>
        </div>
      </div>
      <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-primary/10 blur-[100px] rounded-full"></div>
    </div>
  </section>
</main>

<!-- FOOTER -->
<footer class="bg-[#0a0e16] pt-16 pb-8 border-t border-[#414751]/10">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-12 px-8 max-w-7xl mx-auto text-sm text-[#dfe2ee]/60 mb-16">
    <div class="space-y-6">
      <div class="text-xl font-black text-[#a1c9ff] font-headline">AYL</div>
      <p class="leading-relaxed max-w-xs">Nettoyage professionnel à Bruxelles et communes environnantes.</p>
      <a href="https://wa.me/32488338952" target="_blank" class="inline-flex items-center gap-2 bg-[#1a472a] border border-[#2d6a44] text-[#4ade80] px-4 py-2 rounded-lg text-sm font-bold hover:bg-[#1f5733] transition-colors">
        💚 WhatsApp
      </a>
    </div>
    <div class="space-y-4">
      <h4 class="text-[#dfe2ee] font-bold uppercase tracking-widest text-xs">Services</h4>
      <ul class="space-y-2">
        <li><a class="hover:text-[#a1c9ff] transition-colors block" href="/services/nettoyage-vitres">Nettoyage de vitres</a></li>
        <li><a class="hover:text-[#a1c9ff] transition-colors block" href="/services/nettoyage-canape">Nettoyage de canapés</a></li>
        <li><a class="hover:text-[#a1c9ff] transition-colors block" href="/services/nettoyage-bureau">Nettoyage de bureaux</a></li>
        <li><a class="hover:text-[#a1c9ff] transition-colors block" href="/services/nettoyage-apres-travaux">Après travaux</a></li>
      </ul>
    </div>
    <div class="space-y-4">
      <h4 class="text-[#dfe2ee] font-bold uppercase tracking-widest text-xs">Navigation</h4>
      <ul class="space-y-2">
        <li><a class="hover:text-[#a1c9ff] transition-colors block" href="/">Accueil</a></li>
        <li><a class="hover:text-[#a1c9ff] transition-colors block" href="/services">Services</a></li>
        <li><a class="hover:text-[#a1c9ff] transition-colors block" href="/contact">Contact</a></li>
      </ul>
    </div>
    <div class="space-y-4">
      <h4 class="text-[#dfe2ee] font-bold uppercase tracking-widest text-xs">Contact</h4>
      <ul class="space-y-2">
        <li><a href="tel:+32488338952" class="hover:text-[#a1c9ff] transition-colors">0488 33 89 52</a></li>
        <li>Bruxelles, Belgique</li>
        <li>Lun–Dim 09:00–17:00</li>
      </ul>
    </div>
  </div>
  <div class="max-w-7xl mx-auto px-8 pt-8 border-t border-[#414751]/10 text-center text-xs text-[#dfe2ee]/30">
    <p>© 2026 AYL Cleaning · Bruxelles · Nettoyage Professionnel</p>
  </div>
</footer>

<!-- WhatsApp FAB -->
<a class="fixed bottom-8 right-8 z-[100] bg-[#25D366] text-white w-16 h-16 rounded-full flex items-center justify-center shadow-2xl hover:scale-110 transition-all" href="https://wa.me/32488338952" target="_blank">
  <svg fill="currentColor" height="32" viewBox="0 0 16 16" width="32" xmlns="http://www.w3.org/2000/svg">
    <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.898 7.898 0 0 0 13.6 2.326zM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.729.729 0 0 0-.529.247c-.182.198-.691.677-.691 1.654 0 .977.71 1.916.81 2.049.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"/>
  </svg>
</a>

</body>
</html>