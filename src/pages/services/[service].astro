---
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Head from '../../components/Head.astro';
import { services } from '../../data/services';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { service: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <Head title={`${service.nom} à Bruxelles`} description={`AYL Cleaning — ${service.nom} professionnel à Bruxelles. ${service.description} Devis gratuit en 24h.`}/>
</head>
<body class="bg-surface text-on-surface font-body">

<Nav currentPage="services"/>

<main>

  <!-- HERO -->
  <section class="relative pt-32 pb-20 px-8 max-w-7xl mx-auto">
    <span class="text-primary uppercase tracking-[0.2em] text-xs font-bold mb-4 block">
      {service.icon} Nos services
    </span>
    <h1 class="font-headline text-5xl md:text-6xl font-extrabold text-on-surface leading-tight max-w-3xl mb-8 tracking-tighter">
      {service.nom}<br/>
      <span class="text-primary">à Bruxelles</span>
    </h1>
    <p class="text-on-surface-variant text-lg max-w-xl leading-relaxed mb-10">
      {service.description} AYL Cleaning intervient chez les particuliers et les professionnels à Bruxelles et communes environnantes.
    </p>
    <div class="flex gap-4 flex-wrap">
      <a href="/contact" class="bg-gradient-to-br from-primary to-[#004d7a] text-on-primary px-8 py-4 rounded-full font-headline font-bold hover:shadow-[0_4px_24px_rgba(0,99,155,0.25)] transition-all duration-200">
        Devis gratuit
      </a>
      <a href="https://wa.me/32488338952" target="_blank" class="bg-surface-container-highest text-on-surface px-8 py-4 rounded-full font-headline font-bold hover:bg-surface-container-high transition-all duration-200">
        💚 WhatsApp
      </a>
    </div>
  </section>

  <!-- DETAILS -->
  <section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0_4px_48px_rgba(26,28,30,0.04)]">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">verified</span>
          <h3 class="font-headline font-bold text-lg mb-3">Résultats garantis</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Pas satisfait ? On revient sans frais. Votre satisfaction est notre priorité absolue.</p>
        </div>
        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0_4px_48px_rgba(26,28,30,0.04)]">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">speed</span>
          <h3 class="font-headline font-bold text-lg mb-3">Intervention rapide</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Disponible 7j/7 de 9h à 17h. Réponse sous 24h pour tout devis.</p>
        </div>
        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0_4px_48px_rgba(26,28,30,0.04)]">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">eco</span>
          <h3 class="font-headline font-bold text-lg mb-3">Produits écologiques</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Produits professionnels sans danger pour votre famille et vos animaux.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ZONES -->
  <section class="py-24 px-8 max-w-7xl mx-auto">
    <h2 class="font-headline text-3xl font-extrabold mb-8 tracking-tighter">
      Zones d'intervention — <span class="text-primary">{service.nom}</span>
    </h2>
    <p class="text-on-surface-variant mb-8">Nous intervenons dans toutes les communes de Bruxelles :</p>
    <div class="flex flex-wrap gap-3">
      {['bruxelles', 'anderlecht', 'ixelles', 'uccle', 'etterbeek', 'forest', 'schaerbeek', 'molenbeek', 'saint-gilles', 'laeken'].map(commune => (
        <a href={`/zones/${commune}/${service.slug}`} class="bg-surface-container-lowest text-on-surface-variant px-4 py-2 rounded-full text-sm hover:text-primary hover:bg-surface-container-highest transition-all duration-200 shadow-[0_2px_8px_rgba(26,28,30,0.06)] capitalize">
          📍 {commune}
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-8">
    <div class="max-w-4xl mx-auto bg-gradient-to-br from-primary to-[#004d7a] rounded-3xl p-16 text-center shadow-[0_8px_48px_rgba(0,99,155,0.18)]">
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold mb-6 tracking-tighter text-on-primary">
        Besoin d'un <span class="opacity-80">{service.nom}</span> ?
      </h2>
      <p class="text-on-primary/70 text-lg mb-10">
        Contactez AYL Cleaning pour un devis gratuit sous 24h.
      </p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="/contact" class="bg-white text-primary px-10 py-4 rounded-full font-headline font-bold hover:scale-105 transition-transform duration-200">
          Demander un devis
        </a>
        <a href="https://wa.me/32488338952" target="_blank" class="bg-white/20 text-on-primary px-10 py-4 rounded-full font-headline font-bold hover:bg-white/30 transition-all duration-200">
          💚 WhatsApp
        </a>
      </div>
    </div>
  </section>

</main>

<Footer/>

</body>
</html>