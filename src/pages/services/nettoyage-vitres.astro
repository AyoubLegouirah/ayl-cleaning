---
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Head from '../../components/Head.astro';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <Head
    title="Nettoyage de vitres à Bruxelles — AYL Cleaning"
    description="Nettoyage professionnel de vitres à Bruxelles. Fenêtres, baies vitrées, vérandas, châssis. Résultat sans traces garanti, intérieur et extérieur. Intervention 7j/7. Devis gratuit — +32 488 33 89 52."
  />
</head>
<body class="bg-surface text-on-surface font-body">

<Nav currentPage="vitres"/>

<main>

  <!-- HERO -->
  <section class="relative min-h-[60vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-r from-white via-white/90 to-transparent z-10"></div>
      <img
        alt="Grandes fenêtres lumineuses nettoyées par AYL Cleaning à Bruxelles"
        class="w-full h-full object-cover"
        src="https://images.unsplash.com/photo-1604014237800-1c9102c219da?w=1920&q=80"
      />
    </div>
    <div class="relative z-20 pt-32 pb-20 px-8 max-w-7xl mx-auto w-full">
      <span class="text-primary uppercase tracking-[0.2em] text-xs font-bold mb-4 block">
        🪟 Nettoyage de vitres
      </span>
      <h1 class="font-headline text-5xl md:text-6xl font-extrabold text-on-surface leading-tight max-w-3xl mb-6 tracking-tighter">
        Nettoyage de vitres<br/>
        <span class="text-primary">à Bruxelles</span>
      </h1>
      <p class="text-on-surface-variant text-lg max-w-2xl leading-relaxed mb-10">
        Des vitres impeccables, sans traces ni auréoles. AYL Cleaning intervient à domicile à Bruxelles pour le lavage de vos fenêtres, baies vitrées, vérandas et châssis — intérieur et extérieur, particuliers et professionnels.
      </p>
      <div class="flex gap-4 flex-wrap">
        <a href="/contact" class="bg-gradient-to-br from-primary to-[#004d7a] text-on-primary px-8 py-4 rounded-full font-headline font-bold hover:shadow-[0_4px_24px_rgba(0,99,155,0.25)] transition-all duration-200">
          Devis gratuit
        </a>
        <a href="https://wa.me/32488338952" target="_blank" class="bg-surface-container-highest text-on-surface px-8 py-4 rounded-full font-headline font-bold hover:bg-surface-container-high transition-all duration-200">
          💚 WhatsApp
        </a>
        <a href="tel:+32488338952" class="bg-surface-container-highest text-on-surface px-8 py-4 rounded-full font-headline font-bold hover:bg-surface-container-high transition-all duration-200">
          📞 +32 488 33 89 52
        </a>
      </div>
    </div>
  </section>

  <!-- AVANTAGES -->
  <section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0_4px_48px_rgba(26,28,30,0.04)]">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">verified</span>
          <h3 class="font-headline font-bold text-lg mb-3">Sans traces garanti</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Technique professionnelle à la raclette et produits sans résidus. Zéro auréole, zéro trace de calcaire.</p>
        </div>
        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0_4px_48px_rgba(26,28,30,0.04)]">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">home</span>
          <h3 class="font-headline font-bold text-lg mb-3">Intérieur & extérieur</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Les deux faces nettoyées en une seule intervention. Châssis, rebords et encadrements inclus.</p>
        </div>
        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0_4px_48px_rgba(26,28,30,0.04)]">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">eco</span>
          <h3 class="font-headline font-bold text-lg mb-3">Produits écologiques</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Nettoyants vitrerie professionnels biodégradables, sans danger pour votre famille et l'environnement.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTENU SEO -->
  <section class="py-24 px-8 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
      <div>
        <h2 class="font-headline text-3xl font-extrabold mb-6 tracking-tighter">
          Pourquoi faire laver<br/><span class="text-primary">vos vitres par un pro ?</span>
        </h2>
        <p class="text-on-surface-variant leading-relaxed mb-4">
          À Bruxelles, la pollution urbaine, la pluie calcaire et la poussière encrassent rapidement les surfaces vitrées. Un lavage amateur laisse souvent des traces, des auréoles de calcaire et des résidus de produits ménagers difficiles à éliminer ensuite.
        </p>
        <p class="text-on-surface-variant leading-relaxed mb-4">
          Notre technique professionnelle combine un <strong class="text-on-surface">nettoyant vitrerie concentré</strong>, une éponge de lavage et une raclette de précision pour un résultat impeccable sur toutes les surfaces vitrées : fenêtres simples, doubles vitrages, baies vitrées, portes-fenêtres, vérandas et vitrines de commerces. Les châssis, rebords et encadrements sont nettoyés dans le même passage.
        </p>
        <p class="text-on-surface-variant leading-relaxed">
          Nous recommandons un lavage de vitres tous les 3 à 4 mois pour les particuliers, et mensuel pour les commerces et bureaux avec vitrine. Un entretien régulier évite l'accumulation de calcaire et prolonge la durée de vie de vos châssis.
        </p>
      </div>
      <div class="space-y-4">
        <h3 class="font-headline font-bold text-xl mb-4">Ce qu'on nettoie :</h3>
        {[
          { icon: "window", label: "Fenêtres simples et doubles vitrages" },
          { icon: "door_sliding", label: "Baies vitrées et portes-fenêtres" },
          { icon: "deck", label: "Vérandas et jardins d'hiver" },
          { icon: "storefront", label: "Vitrines de commerces et bureaux" },
          { icon: "roofing", label: "Velux et fenêtres de toit accessibles" },
          { icon: "cleaning_services", label: "Châssis, rebords et encadrements" },
        ].map(item => (
          <div class="flex items-center gap-4 bg-surface-container-lowest rounded-xl px-6 py-4 shadow-[0_2px_16px_rgba(26,28,30,0.04)]">
            <span class="material-symbols-outlined text-primary">{item.icon}</span>
            <span class="text-on-surface-variant text-sm">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TECHNIQUE & PRODUITS -->
  <section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-headline text-3xl font-extrabold mb-4 tracking-tighter text-center">
        Notre technique de <span class="text-primary">lavage de vitres</span>
      </h2>
      <p class="text-on-surface-variant text-center max-w-2xl mx-auto mb-12">Une méthode professionnelle éprouvée pour des vitres impeccables et durables.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          {
            icon: "water_drop",
            title: "Nettoyant vitrerie concentré",
            desc: "Nos produits professionnels dissolvent le calcaire, la pollution et les traces de doigts sans laisser de résidus ni d'auréoles sur les surfaces vitrées."
          },
          {
            icon: "straighten",
            title: "Raclette de précision",
            desc: "La raclette professionnelle évacue l'eau et la saleté en un seul passage, sans laisser de traces. Résultat parfait sur toutes les tailles de vitres."
          },
          {
            icon: "shield",
            title: "Traitement hydrophobe",
            desc: "Après le lavage, on applique un traitement anti-calcaire qui repousse l'eau et la poussière. Vos vitres restent propres 2 à 3 fois plus longtemps."
          },
          {
            icon: "eco",
            title: "Produits biodégradables",
            desc: "Tous nos nettoyants vitrerie sont biodégradables et sans solvants agressifs. Méthode écologique, sans danger pour vos plantes et votre jardin."
          },
        ].map(item => (
          <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0_4px_48px_rgba(26,28,30,0.04)]">
            <span class="material-symbols-outlined text-primary text-3xl mb-4 block">{item.icon}</span>
            <h3 class="font-headline font-bold text-lg mb-3">{item.title}</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESSUS -->
  <section class="py-24 px-8 max-w-7xl mx-auto">
    <h2 class="font-headline text-3xl font-extrabold mb-12 tracking-tighter text-center">
      Comment se passe <span class="text-primary">l'intervention ?</span>
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      {[
        { step: "01", icon: "phone_in_talk", title: "Devis gratuit", desc: "Appelez-nous ou envoyez une photo de vos fenêtres par WhatsApp. Prix fixe communiqué sous 24h." },
        { step: "02", icon: "calendar_month", title: "Rendez-vous", desc: "On fixe un créneau à votre convenance, 7j/7 de 9h à 17h, en semaine ou week-end." },
        { step: "03", icon: "cleaning_services", title: "Lavage à domicile", desc: "Notre laveur de vitres arrive avec tout le matériel. Lavage, rinçage, raclage et nettoyage des châssis." },
        { step: "04", icon: "check_circle", title: "Résultat immédiat", desc: "Vitres impeccables, sans traces ni calcaire, intérieur et extérieur. Résultat visible immédiatement." },
      ].map(item => (
        <div class="relative bg-surface-container-lowest rounded-xl p-8 shadow-[0_4px_48px_rgba(26,28,30,0.04)]">
          <span class="text-primary/20 font-headline font-extrabold text-6xl absolute top-4 right-6">{item.step}</span>
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">{item.icon}</span>
          <h3 class="font-headline font-bold text-lg mb-3">{item.title}</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- TARIFS -->
  <section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-headline text-3xl font-extrabold mb-4 tracking-tighter">
        Tarifs indicatifs —<span class="text-primary"> Nettoyage vitres</span>
      </h2>
      <p class="text-on-surface-variant mb-10">Prix indicatifs pour Bruxelles et communes. Devis gratuit et personnalisé sur demande.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { label: "Appartement", price: "À partir de 40€", desc: "Jusqu'à 8 fenêtres, intérieur et extérieur, châssis et rebords inclus" },
          { label: "Maison", price: "À partir de 70€", desc: "Jusqu'à 15 fenêtres, baies vitrées et portes-fenêtres, traitement hydrophobe inclus" },
          { label: "Commerce / Bureau", price: "Sur devis", desc: "Vitrines, cloisons vitrées, entretien régulier avec contrat mensuel possible" },
        ].map(item => (
          <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0_4px_48px_rgba(26,28,30,0.04)] flex flex-col gap-3">
            <h3 class="font-headline font-bold text-lg">{item.label}</h3>
            <p class="text-primary font-headline font-extrabold text-3xl">{item.price}</p>
            <p class="text-on-surface-variant text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
      <p class="text-on-surface-variant/60 text-xs mt-6">* Prix indicatifs hors déplacement. Tarif exact confirmé après évaluation. Déplacement gratuit dans un rayon de 20km autour de Bruxelles.</p>
    </div>
  </section>

  <!-- SIGNES QUE VOS VITRES ONT BESOIN D'UN PRO -->
  <section class="py-24 px-8 max-w-7xl mx-auto">
    <h2 class="font-headline text-3xl font-extrabold mb-4 tracking-tighter">
      Vos vitres ont besoin d'un <span class="text-primary">lavage professionnel</span> si…
    </h2>
    <p class="text-on-surface-variant mb-12 max-w-2xl">
      Des vitres sales ou mal nettoyées ternissent l'image de votre intérieur et laissent entrer moins de lumière naturelle. Voici les signes qui indiquent qu'il est temps d'appeler un professionnel.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { icon: "water_drop", titre: "Traces de calcaire incrustées", desc: "Les dépôts calcaires laissés par la pluie s'incrustent dans le verre avec le temps. Ils deviennent impossibles à éliminer avec un chiffon ordinaire et nécessitent un nettoyant anti-calcaire professionnel." },
        { icon: "wb_cloudy", titre: "Auréoles et traces après nettoyage", desc: "Vous nettoyez vos vitres mais elles sont encore plus striées qu'avant ? C'est le signe d'un mauvais produit ou d'une mauvaise technique. Nos nettoyeurs professionnels utilisent raclette et produit vitrerie sans résidus." },
        { icon: "light_mode", titre: "Moins de lumière naturelle", desc: "Des vitres encrassées par la pollution, la poussière et la saleté urbaine de Bruxelles filtrent jusqu'à 30% de lumière en moins. Un lavage complet restitue instantanément la luminosité de vos pièces." },
        { icon: "storefront", titre: "Image de votre commerce", desc: "Une vitrine sale donne une mauvaise première impression à vos clients. Pour les commerces et bureaux à Bruxelles, des vitres impeccables sont un élément essentiel de votre image professionnelle." },
        { icon: "calendar_month", titre: "Plus de 3 mois sans lavage", desc: "La pollution bruxelloise, les pluies calcaires et la poussière encrassent rapidement les surfaces vitrées. Un lavage tous les 3 à 4 mois est recommandé pour les particuliers, mensuel pour les commerces." },
        { icon: "home", titre: "Véranda ou grande baie vitrée", desc: "Les vérandas, jardins d'hiver et grandes baies vitrées accumulent mousses, salissures et calcaire sur toute leur surface. Leur nettoyage complet intérieur et extérieur demande un matériel professionnel adapté." },
      ].map(item => (
        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0_4px_48px_rgba(26,28,30,0.04)]">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">{item.icon}</span>
          <h3 class="font-headline font-bold text-lg mb-3">{item.titre}</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- POURQUOI PAS FAIRE SOI-MÊME -->
  <section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="font-headline text-3xl font-extrabold mb-6 tracking-tighter">
          Pourquoi le nettoyage amateur <span class="text-primary">laisse des traces ?</span>
        </h2>
        <p class="text-on-surface-variant leading-relaxed mb-4">
          Nettoyer ses vitres soi-même semble simple — mais le résultat est rarement à la hauteur. Les produits ménagers courants comme le liquide-vaisselle, le vinaigre blanc ou les sprays du commerce laissent des résidus qui attirent la poussière et créent des auréoles visibles dès que la lumière frappe la vitre.
        </p>
        <p class="text-on-surface-variant leading-relaxed mb-4">
          Les chiffons ordinaires et le papier journal laissent des peluches et des micro-rayures sur les surfaces vitrées. Essuyer sans raclette crée inévitablement des traces en S visibles à contre-jour. Et nettoyer en plein soleil fait sécher le produit trop vite — résultat garanti : des auréoles de calcaire encore plus visibles qu'avant.
        </p>
        <p class="text-on-surface-variant leading-relaxed">
          Nos laveurs de vitres professionnels utilisent un nettoyant vitrerie concentré sans résidus, une raclette de précision et des chiffons microfibre pour un résultat impeccable et durable — sans traces, sans auréoles, sans effort de votre côté.
        </p>
      </div>
      <div class="space-y-4">
        {[
          { label: "Liquide-vaisselle ou spray du commerce", pro: false, desc: "Laisse des résidus collants qui attirent la poussière et créent des auréoles" },
          { label: "Chiffon ordinaire ou papier journal", pro: false, desc: "Peluches, micro-rayures et traces inévitables sur les surfaces vitrées" },
          { label: "Nettoyage en plein soleil", pro: false, desc: "Séchage trop rapide, dépôts de calcaire et auréoles garantis" },
          { label: "Nettoyant vitrerie professionnel", pro: true, desc: "Sans résidus ni auréoles, anti-calcaire, résultat impeccable et durable" },
          { label: "Raclette de précision + chiffon microfibre", pro: true, desc: "Évacue l'eau et les saletés en un passage, sans traces ni peluches" },
          { label: "Traitement hydrophobe après lavage", pro: true, desc: "Repousse l'eau et la poussière — vos vitres restent propres 2 à 3 fois plus longtemps" },
        ].map(item => (
          <div class={`flex items-center gap-4 rounded-xl px-6 py-4 ${item.pro ? 'bg-primary/5' : 'bg-surface-container shadow-[0_2px_8px_rgba(26,28,30,0.04)]'}`}>
            <span class={`material-symbols-outlined text-xl ${item.pro ? 'text-primary' : 'text-red-400'}`}>
              {item.pro ? 'check_circle' : 'cancel'}
            </span>
            <div>
              <p class={`text-sm font-bold ${item.pro ? 'text-on-surface' : 'text-on-surface-variant'}`}>{item.label}</p>
              <p class="text-on-surface-variant text-xs">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-24 px-8">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-headline text-3xl font-extrabold mb-12 tracking-tighter">
        Questions fréquentes —<span class="text-primary"> Nettoyage vitres</span>
      </h2>
      <div class="space-y-4">
        {[
          {
            q: "Vous nettoyez aussi bien l'intérieur que l'extérieur ?",
            a: "Oui, nous traitons systématiquement les deux faces en une seule intervention. Les châssis, rebords et encadrements sont également nettoyés sans supplément. Pas besoin de prévoir deux rendez-vous séparés."
          },
          {
            q: "Pouvez-vous éliminer les traces de calcaire tenaces ?",
            a: "Oui, nous utilisons des nettoyants vitrerie professionnels anti-calcaire qui dissolvent les dépôts minéraux sans rayer les surfaces vitrées. Après le lavage, on applique un traitement hydrophobe qui empêche le calcaire de se redéposer."
          },
          {
            q: "Combien de temps dure l'intervention ?",
            a: "Comptez 30 à 45 minutes pour un appartement avec 6 à 8 fenêtres, et jusqu'à 2 heures pour une grande maison avec baies vitrées et véranda. Nous estimons la durée lors du devis."
          },
          {
            q: "Vous intervenez pour les commerces et bureaux ?",
            a: "Oui, nous nettoyons les vitrines de commerces, cloisons vitrées et fenêtres de bureaux. Nous proposons aussi des contrats d'entretien régulier mensuel ou trimestriel pour les professionnels à Bruxelles."
          },
          {
            q: "Est-ce que les vitres restent propres longtemps après le nettoyage ?",
            a: "Nous appliquons un traitement hydrophobe après chaque lavage qui repousse l'eau, la poussière et la pollution. Vos vitres restent propres 2 à 3 fois plus longtemps qu'avec un nettoyage classique."
          },
          {
            q: "Comment obtenir un devis pour mes vitres ?",
            a: "Appelez-nous au +32 488 33 89 52 ou envoyez-nous un message WhatsApp avec une photo de vos fenêtres. Nous vous répondons sous 24h avec un prix fixe et sans surprise."
          },
        ].map((item) => (
          <details class="bg-surface-container-lowest rounded-xl group shadow-[0_2px_16px_rgba(26,28,30,0.04)]">
            <summary class="px-8 py-6 font-headline font-bold cursor-pointer flex justify-between items-center list-none">
              <span>{item.q}</span>
              <span class="material-symbols-outlined text-primary group-open:rotate-180 transition-transform">expand_more</span>
            </summary>
            <p class="px-8 pb-6 text-on-surface-variant text-sm leading-relaxed">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ZONES -->
  <section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-headline text-3xl font-extrabold mb-4 tracking-tighter">
        Zones d'intervention — <span class="text-primary">Vitres Bruxelles</span>
      </h2>
      <p class="text-on-surface-variant mb-8">Nous intervenons dans toutes les communes de Bruxelles :</p>
      <div class="flex flex-wrap gap-3">
        {[
          { slug: 'bruxelles', label: 'Bruxelles' },
          { slug: 'anderlecht', label: 'Anderlecht' },
          { slug: 'ixelles', label: 'Ixelles' },
          { slug: 'uccle', label: 'Uccle' },
          { slug: 'etterbeek', label: 'Etterbeek' },
          { slug: 'forest', label: 'Forest' },
          { slug: 'schaerbeek', label: 'Schaerbeek' },
          { slug: 'molenbeek', label: 'Molenbeek' },
          { slug: 'saint-gilles', label: 'Saint-Gilles' },
          { slug: 'laeken', label: 'Laeken' },
        ].map(c => (
          <a href={`/zones/${c.slug}/nettoyage-vitres`} class="bg-surface-container-lowest text-on-surface-variant px-4 py-2 rounded-full text-sm hover:text-primary hover:bg-surface-container-highest transition-all duration-200 shadow-[0_2px_8px_rgba(26,28,30,0.06)]">
            📍 {c.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="py-24 px-8">
    <div class="max-w-4xl mx-auto bg-gradient-to-br from-primary to-[#004d7a] rounded-3xl p-16 text-center shadow-[0_8px_48px_rgba(0,99,155,0.18)]">
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold mb-4 tracking-tighter text-on-primary">
        Des vitres impeccables<br/><span class="opacity-80">sans traces ni calcaire</span>
      </h2>
      <p class="text-on-primary/70 text-lg mb-10 max-w-xl mx-auto">
        Lavage intérieur et extérieur, châssis inclus. Devis gratuit en 24h. Intervention 7j/7 à Bruxelles.
      </p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="/contact" class="bg-white text-primary px-10 py-4 rounded-full font-headline font-bold hover:scale-105 transition-transform duration-200">
          Demander un devis gratuit
        </a>
        <a href="https://wa.me/32488338952" target="_blank" class="bg-white/20 text-on-primary px-10 py-4 rounded-full font-headline font-bold hover:bg-white/30 transition-all duration-200">
          💚 WhatsApp
