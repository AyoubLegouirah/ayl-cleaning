---
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import Head from '../../../components/Head.astro';
import { zones } from '../../../data/communes';

export function getStaticPaths() {
  return zones.flatMap(zone =>
    zone.villes.map(ville => ({
      params: { region: zone.slug, ville: ville.slug },
      props: { zone, ville },
    }))
  );
}

const { zone, ville } = Astro.props;
const metaDescription = `Nettoyage de canapé à ${ville.nom} — AYL Cleaning intervient à domicile 7j/7. Tissu, cuir, velours. Devis gratuit et sans engagement. Résultat garanti dans tout ${ville.nom} et ses environs.`;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <Head
    title={`Nettoyage canapé ${ville.nom} | AYL Cleaning`}
    description={metaDescription}
    canonical={`/canape/${zone.slug}/${ville.slug}`}
  />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "AYL Cleaning",
    "description": `Nettoyage professionnel de canapés à ${ville.nom}`,
    "url": `https://aylcleaning.be/canape/${zone.slug}/${ville.slug}`,
    "telephone": "+32488338952",
    "areaServed": {
      "@type": "City",
      "name": ville.nom
    },
    "serviceType": "Nettoyage de canapés"
  })} />
</head>
<body class="bg-surface text-on-surface font-body">

<Nav currentPage="canape"/>

<main>

  <!-- HERO -->
  <section class="relative pt-32 pb-20 px-8">
    <div class="max-w-7xl mx-auto">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-on-surface-variant mb-8 flex-wrap" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-primary transition-colors">Accueil</a>
        <span class="material-symbols-outlined text-base">chevron_right</span>
        <a href="/canape" class="hover:text-primary transition-colors">Canapé</a>
        <span class="material-symbols-outlined text-base">chevron_right</span>
        <a href={`/canape/${zone.slug}`} class="hover:text-primary transition-colors">{zone.region}</a>
        <span class="material-symbols-outlined text-base">chevron_right</span>
        <span class="text-on-surface font-medium">{ville.nom}</span>
      </nav>

      <span class="text-primary uppercase tracking-[0.2em] text-xs font-bold mb-4 block">
        🛋️ Nettoyage de canapés — {ville.nom}
      </span>
      <h1 class="font-headline text-5xl md:text-6xl font-extrabold text-on-surface leading-tight max-w-3xl mb-6 tracking-tighter">
        Nettoyage de canapé<br/>
        <span class="text-primary">à {ville.nom}</span>
      </h1>
      <p class="text-on-surface-variant text-lg max-w-2xl leading-relaxed mb-10">
        AYL Cleaning intervient directement à votre domicile à {ville.nom} pour le nettoyage professionnel de vos canapés, fauteuils et sièges. Détachage des taches, désinfection, traitement anti-acariens — résultat garanti, séchage en 2 à 4 heures.
      </p>
      <div class="flex gap-4 flex-wrap">
        <a href="/contact" class="bg-gradient-to-br from-primary to-[#004d7a] text-on-primary px-8 py-4 rounded-full font-headline font-bold hover:shadow-[0_4px_24px_rgba(0,99,155,0.25)] transition-all duration-200">
          Devis gratuit
        </a>
        <a href="https://wa.me/32488338952" target="_blank" class="bg-surface-container-highest text-on-surface px-8 py-4 rounded-full font-headline font-bold hover:bg-surface-container-high transition-all duration-200">
          💚 WhatsApp
        </a>
        <a href="tel:+32488338952" class="bg-surface-container-highest text-on-surface px-8 py-4 rounded-full font-headline font-bold hover:bg-surface-container-high transition-all duration-200">
          📞 +32 488 33 89 52
        </a>
      </div>
    </div>
  </section>

  <!-- CONTENU UNIQUE PAR VILLE -->
  <section class="py-24 px-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
        <div>
          <h2 class="font-headline text-3xl font-extrabold mb-6 tracking-tighter">
            Nettoyage de canapé <span class="text-primary">à {ville.nom}</span> — pourquoi nous choisir ?
          </h2>
          <div class="space-y-4 text-on-surface-variant leading-relaxed">
            <p>
              AYL Cleaning propose un service de nettoyage de canapé à domicile à {ville.nom} et dans toute la région de {zone.region}. Nos techniciens se déplacent chez vous avec l'équipement professionnel complet : machine d'extraction, nettoyants enzymatiques biodégradables et spray désinfectant anti-acariens.
            </p>
            <p>
              À {ville.nom}, nous intervenons pour les particuliers, les familles avec enfants ou animaux, et les propriétaires qui souhaitent remettre leur bien en état avant une location ou une vente. Chaque canapé est traité selon son type de tissu — microfibre, velours, cuir, similicuir ou tissu synthétique — pour garantir un résultat optimal sans endommager les fibres.
            </p>
            <p>
              Notre technique d'extraction à faible humidité élimine en profondeur les acariens, les bactéries, les allergènes et les odeurs tenaces incrustées dans les rembourrages. Le canapé sèche en 2 à 4 heures et est immédiatement réutilisable. Nous traitons toutes les taches courantes : vin, café, urine, sang et graisses alimentaires.
            </p>
            <p>
              Pour un nettoyage de canapé à {ville.nom}, contactez-nous par téléphone ou WhatsApp pour obtenir un devis gratuit sous 24h. Le déplacement est gratuit pour toutes les communes de {zone.region}.
            </p>
          </div>
        </div>
        <div class="space-y-4">
          <h3 class="font-headline font-bold text-xl mb-4">Notre prestation à {ville.nom} inclut :</h3>
          {[
            { icon: "cleaning_services", label: "Inspection et test de compatibilité du tissu" },
            { icon: "local_laundry_service", label: "Détachage ciblé de toutes les taches" },
            { icon: "water_drop", label: "Lavage par extraction à faible humidité" },
            { icon: "sanitizer", label: "Désinfection et traitement anti-acariens" },
            { icon: "air", label: "Désodorisation des fibres et rembourrages" },
            { icon: "speed", label: "Séchage en 2 à 4 heures" },
          ].map(item => (
            <div class="flex items-center gap-4 bg-surface-container-lowest rounded-xl px-6 py-4 shadow-[0_2px_16px_rgba(26,28,30,0.04)]">
              <span class="material-symbols-outlined text-primary">{item.icon}</span>
              <span class="text-on-surface-variant text-sm">{item.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- TARIFS -->
  <section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-headline text-3xl font-extrabold mb-4 tracking-tighter">
        Tarifs — <span class="text-primary">Nettoyage canapé à {ville.nom}</span>
      </h2>
      <p class="text-on-surface-variant mb-10">Prix indicatifs, devis gratuit et personnalisé sur demande.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { label: "Canapé 2 places", price: "À partir de 60€", desc: "Tissu ou microfibre, lavage complet, détachage et désinfection inclus" },
          { label: "Canapé 3 places", price: "À partir de 80€", desc: "Tissu, velours ou similicuir, traitement anti-acariens et désodorisation inclus" },
          { label: "Canapé d'angle", price: "À partir de 120€", desc: "Grand format, méridienne incluse, détachage taches tenaces, séchage rapide garanti" },
        ].map(item => (
          <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0_4px_48px_rgba(26,28,30,0.04)] flex flex-col gap-3">
            <h3 class="font-headline font-bold text-lg">{item.label}</h3>
            <p class="text-primary font-headline font-extrabold text-3xl">{item.price}</p>
            <p class="text-on-surface-variant text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
      <p class="text-on-surface-variant/60 text-xs mt-6">* Déplacement gratuit pour {ville.nom} et toute la région {zone.region}.</p>
    </div>
  </section>

  <!-- LIEN RETOUR + AUTRES COMMUNES -->
  <section class="py-16 px-8">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div>
          <p class="text-on-surface-variant text-sm mb-2">Nous intervenons aussi dans les autres communes de {zone.region} :</p>
          <a href={`/canape/${zone.slug}`} class="inline-flex items-center gap-2 text-primary font-headline font-bold hover:underline">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            Voir toutes les communes de {zone.region}
          </a>
        </div>
        <a href="/canape" class="inline-flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors font-headline font-bold text-sm">
          <span class="material-symbols-outlined text-base">arrow_back</span>
          Retour à la page canapé
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-8">
    <div class="max-w-4xl mx-auto bg-gradient-to-br from-primary to-[#004d7a] rounded-3xl p-12 text-center shadow-[0_8px_48px_rgba(0,99,155,0.18)]">
      <h2 class="font-headline text-2xl md:text-3xl font-extrabold mb-4 tracking-tighter text-on-primary">
        Canapé à nettoyer à {ville.nom} ?
      </h2>
      <p class="text-on-primary/70 text-base mb-8 max-w-xl mx-auto">
        Contactez AYL Cleaning pour un devis gratuit sous 24h. Déplacement gratuit à {ville.nom}.
      </p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="/contact" class="bg-white text-primary px-8 py-3 rounded-full font-headline font-bold hover:scale-105 transition-transform duration-200">
          Demander un devis
        </a>
        <a href="https://wa.me/32488338952" target="_blank" class="bg-white/20 text-on-primary px-8 py-3 rounded-full font-headline font-bold hover:bg-white/30 transition-all duration-200">
          💚 WhatsApp
        </a>
      </div>
    </div>
  </section>

</main>

<Footer/>

</body>
</html>
