---
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Head from '../../components/Head.astro';
import { zones } from '../../data/communes';

export function getStaticPaths() {
  return zones.map(zone => ({
    params: { region: zone.slug },
    props: { zone },
  }));
}

const { zone } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <Head
    title={`Nettoyage canapé ${zone.region} | AYL Cleaning`}
    description={`Nettoyage professionnel de canapés en ${zone.region}. AYL Cleaning intervient à domicile dans toutes les communes. Détachage, désinfection, anti-acariens. Devis gratuit — +32 488 33 89 52.`}
    canonical={`/canape/${zone.slug}`}
  />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "AYL Cleaning",
    "description": `Nettoyage professionnel de canapés en ${zone.region}`,
    "url": `https://aylcleaning.be/canape/${zone.slug}`,
    "telephone": "+32488338952",
    "areaServed": {
      "@type": "AdministrativeArea",
      "name": zone.region
    },
    "serviceType": "Nettoyage de canapés"
  })} />
</head>
<body class="bg-surface text-on-surface font-body">

<Nav currentPage="canape"/>

<main>

  <!-- HERO -->
  <section class="relative pt-32 pb-20 px-8">
    <div class="max-w-7xl mx-auto">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-on-surface-variant mb-8" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-primary transition-colors">Accueil</a>
        <span class="material-symbols-outlined text-base">chevron_right</span>
        <a href="/canape" class="hover:text-primary transition-colors">Canapé</a>
        <span class="material-symbols-outlined text-base">chevron_right</span>
        <span class="text-on-surface font-medium">{zone.region}</span>
      </nav>

      <span class="text-primary uppercase tracking-[0.2em] text-xs font-bold mb-4 block">
        🛋️ Nettoyage de canapés — {zone.region}
      </span>
      <h1 class="font-headline text-5xl md:text-6xl font-extrabold text-on-surface leading-tight max-w-3xl mb-6 tracking-tighter">
        Nettoyage de canapé<br/>
        <span class="text-primary">en {zone.region}</span>
      </h1>
      <p class="text-on-surface-variant text-lg max-w-2xl leading-relaxed mb-10">
        AYL Cleaning intervient à domicile dans toutes les communes de {zone.region} pour le nettoyage professionnel de vos canapés, fauteuils et sièges. Détachage des taches tenaces, désinfection, traitement anti-acariens et désodorisation — résultat garanti.
      </p>
      <div class="flex gap-4 flex-wrap">
        <a href="/contact" class="bg-gradient-to-br from-primary to-[#004d7a] text-on-primary px-8 py-4 rounded-full font-headline font-bold hover:shadow-[0_4px_24px_rgba(0,99,155,0.25)] transition-all duration-200">
          Devis gratuit
        </a>
        <a href="https://wa.me/32488338952" target="_blank" class="bg-surface-container-highest text-on-surface px-8 py-4 rounded-full font-headline font-bold hover:bg-surface-container-high transition-all duration-200">
          💚 WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- AVANTAGES -->
  <section class="bg-surface-container-low py-16 px-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0_4px_48px_rgba(26,28,30,0.04)]">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">verified</span>
          <h3 class="font-headline font-bold text-lg mb-3">Résultat garanti</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Pas satisfait ? On revient sans frais. Votre satisfaction est notre priorité absolue.</p>
        </div>
        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0_4px_48px_rgba(26,28,30,0.04)]">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">speed</span>
          <h3 class="font-headline font-bold text-lg mb-3">Séchage en 2 à 4h</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Technique d'extraction à faible humidité. Canapé réutilisable le jour même.</p>
        </div>
        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0_4px_48px_rgba(26,28,30,0.04)]">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">eco</span>
          <h3 class="font-headline font-bold text-lg mb-3">Produits écologiques</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Nettoyants biodégradables, sans danger pour vos enfants et animaux.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRÉSENTATION SERVICE DANS CETTE RÉGION -->
  <section class="py-24 px-8">
    <div class="max-w-7xl mx-auto max-w-3xl">
      <h2 class="font-headline text-3xl font-extrabold mb-6 tracking-tighter">
        Service de nettoyage de canapé <span class="text-primary">en {zone.region}</span>
      </h2>
      <div class="space-y-4 text-on-surface-variant leading-relaxed">
        <p>
          AYL Cleaning propose ses services de nettoyage de canapés dans toute la région de {zone.region}. Nos techniciens se déplacent directement à votre domicile avec l'équipement professionnel complet — aucune contrainte de transport pour vous.
        </p>
        <p>
          Que vous habitiez dans une maison, un appartement ou que vous gériez des locaux professionnels en {zone.region}, nous adaptons notre intervention à votre situation. Chaque canapé est inspecté avant le nettoyage pour identifier les taches, les zones à traiter en priorité et le type de tissu afin d'appliquer le traitement le mieux adapté.
        </p>
        <p>
          Notre technique d'extraction à faible humidité garantit un séchage en 2 à 4 heures seulement — vous pouvez réutiliser votre canapé le jour même. Déplacement gratuit dans un rayon de 20 km autour de Bruxelles.
        </p>
      </div>
    </div>
  </section>

  <!-- COMMUNES COUVERTES -->
  <section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-headline text-3xl font-extrabold mb-4 tracking-tighter">
        Communes couvertes en <span class="text-primary">{zone.region}</span>
      </h2>
      <p class="text-on-surface-variant mb-10">
        Sélectionnez votre commune pour découvrir notre service de nettoyage de canapé localement.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {zone.villes.map(ville => (
          <a
            href={`/canape/${zone.slug}/${ville.slug}`}
            class="group bg-surface-container-lowest rounded-xl px-6 py-5 shadow-[0_2px_16px_rgba(26,28,30,0.04)] hover:shadow-[0_4px_24px_rgba(26,28,30,0.08)] transition-all duration-200 hover:-translate-y-0.5 flex items-center justify-between"
          >
            <div class="flex items-center gap-3">
              <span class="w-2 h-2 rounded-full bg-primary/40 shrink-0"></span>
              <span class="font-headline font-bold text-on-surface group-hover:text-primary transition-colors">{ville.nom}</span>
            </div>
            <span class="material-symbols-outlined text-on-surface-variant/40 group-hover:text-primary transition-colors text-base">arrow_forward_ios</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-8">
    <div class="max-w-4xl mx-auto bg-gradient-to-br from-primary to-[#004d7a] rounded-3xl p-16 text-center shadow-[0_8px_48px_rgba(0,99,155,0.18)]">
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold mb-4 tracking-tighter text-on-primary">
        Nettoyage de canapé en {zone.region} ?
      </h2>
      <p class="text-on-primary/70 text-lg mb-10 max-w-xl mx-auto">
        Contactez AYL Cleaning pour un devis gratuit sous 24h. Intervention à domicile 7j/7.
      </p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="/contact" class="bg-white text-primary px-10 py-4 rounded-full font-headline font-bold hover:scale-105 transition-transform duration-200">
          Demander un devis gratuit
        </a>
        <a href="https://wa.me/32488338952" target="_blank" class="bg-white/20 text-on-primary px-10 py-4 rounded-full font-headline font-bold hover:bg-white/30 transition-all duration-200">
          💚 WhatsApp
        </a>
      </div>
    </div>
  </section>

</main>

<Footer/>

</body>
</html>
