---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Head from '../components/Head.astro';
---

<!DOCTYPE html>
<html class="dark" lang="fr">
<head>
  <Head title="Nettoyage Professionnel à Bruxelles" description="AYL Cleaning — Spécialiste du nettoyage de vitres, canapés et après travaux à Bruxelles. Devis gratuit en 24h."/>
</head>
<body class="bg-surface text-on-surface font-body">

<Nav currentPage="accueil"/>

<main class="relative">

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center pt-20 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-r from-surface via-surface/90 to-transparent z-10"></div>
      <img 
        alt="Intérieur luxueux propre à Bruxelles" 
        class="w-full h-full object-cover"
        src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=1400&q=80"
      />
    </div>
    <div class="relative z-20 max-w-7xl mx-auto px-8 w-full">
      <div class="flex flex-col justify-center space-y-8 max-w-2xl">
        <div class="space-y-4">
          <span class="text-primary font-headline font-bold uppercase tracking-[0.2em] text-sm opacity-80">Nettoyage Professionnel · Bruxelles</span>
          <h1 class="text-5xl md:text-7xl font-headline font-extrabold tracking-tighter leading-none text-on-surface">
            Le nettoyage<br/>
            <span class="text-primary">redéfini.</span>
          </h1>
          <p class="text-lg md:text-xl text-on-surface-variant max-w-lg font-light leading-relaxed">
            Services de nettoyage professionnels pour particuliers et entreprises à Bruxelles. Résultats garantis, intervention rapide.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a href="/contact" class="bg-primary text-on-primary px-8 py-4 rounded-md font-headline font-extrabold text-lg flex items-center justify-center gap-2 hover:bg-primary-container transition-all">
            Devis gratuit
            <span class="material-symbols-outlined">arrow_forward</span>
          </a>
          <a href="/services" class="border border-outline-variant/30 bg-surface/40 backdrop-blur-md text-on-surface px-8 py-4 rounded-md font-headline font-extrabold text-lg hover:bg-surface-container transition-all text-center">
            Nos services
          </a>
        </div>
        <div class="pt-12 flex items-center gap-8 border-t border-outline-variant/10">
          <div class="flex gap-2 text-tertiary">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
          </div>
          <p class="text-sm text-on-surface-variant font-medium">Service 5 étoiles à Bruxelles</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="bg-surface-container-low py-32 relative">
    <div class="max-w-7xl mx-auto px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
        <div class="space-y-4">
          <span class="text-primary font-headline font-bold uppercase tracking-widest text-xs">Nos expertises</span>
          <h2 class="text-4xl md:text-5xl font-headline font-extrabold tracking-tighter">Nos Services</h2>
        </div>
        <p class="text-on-surface-variant max-w-sm font-light">
          Des solutions sur-mesure pour particuliers et professionnels à Bruxelles.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Canapé en premier -->
        <div class="group relative overflow-hidden bg-surface-container p-8 rounded-xl transition-all duration-500 hover:-translate-y-2 border border-outline-variant/5">
          <div class="relative z-10 space-y-8">
            <div class="bg-primary/10 w-16 h-16 rounded-lg flex items-center justify-center text-primary">
              <span class="material-symbols-outlined text-3xl">chair</span>
            </div>
            <div class="space-y-4">
              <h3 class="text-2xl font-headline font-bold text-on-surface">Nettoyage de canapés</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed">Canapés, fauteuils, sièges. Extraction en profondeur, traitement vapeur, séchage rapide. Résultats garantis.</p>
            </div>
            <div class="flex gap-3">
              <a class="flex-1 border border-outline-variant/30 px-4 py-3 rounded-md hover:border-primary hover:text-primary transition-all font-bold text-sm text-center" href="/services/nettoyage-canape">
                En savoir plus →
              </a>
              <a class="flex-1 bg-primary text-on-primary px-4 py-3 rounded-md font-bold text-sm text-center hover:bg-primary-container transition-all" href="/contact">
                Devis gratuit
              </a>
            </div>
          </div>
        </div>

        <!-- Vitres en second -->
        <div class="group relative overflow-hidden bg-surface-container p-8 rounded-xl transition-all duration-500 hover:-translate-y-2 border border-outline-variant/5">
          <div class="relative z-10 space-y-8">
            <div class="bg-primary/10 w-16 h-16 rounded-lg flex items-center justify-center text-primary">
              <span class="material-symbols-outlined text-3xl">window</span>
            </div>
            <div class="space-y-4">
              <h3 class="text-2xl font-headline font-bold text-on-surface">Nettoyage de vitres</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed">Fenêtres, baies vitrées, vérandas et vitrines. Résultat sans traces garanti, intérieur et extérieur.</p>
            </div>
            <div class="flex gap-3">
              <a class="flex-1 border border-outline-variant/30 px-4 py-3 rounded-md hover:border-primary hover:text-primary transition-all font-bold text-sm text-center" href="/services/nettoyage-vitres">
                En savoir plus →
              </a>
              <a class="flex-1 bg-primary text-on-primary px-4 py-3 rounded-md font-bold text-sm text-center hover:bg-primary-container transition-all" href="/contact">
                Devis gratuit
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- POURQUOI -->
  <section class="py-32 bg-surface">
    <div class="max-w-7xl mx-auto px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
        <div class="lg:col-span-5 space-y-8">
          <h2 class="text-4xl md:text-5xl font-headline font-extrabold tracking-tighter leading-tight">
            Pourquoi choisir <span class="text-primary">AYL Cleaning ?</span>
          </h2>
          <p class="text-on-surface-variant leading-relaxed">
            Nous ne nettoyons pas, nous transformons vos espaces. Nos standards sont définis par les exigences de nos clients les plus exigeants à Bruxelles.
          </p>
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="bg-secondary-container text-secondary p-2 rounded-lg">
                <span class="material-symbols-outlined">verified</span>
              </div>
              <div>
                <h4 class="font-bold font-headline">Professionnels formés</h4>
                <p class="text-sm text-on-surface-variant">Personnel expérimenté et de confiance.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="bg-secondary-container text-secondary p-2 rounded-lg">
                <span class="material-symbols-outlined">eco</span>
              </div>
              <div>
                <h4 class="font-bold font-headline">Produits écologiques</h4>
                <p class="text-sm text-on-surface-variant">Produits sans danger pour votre famille et vos animaux.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="bg-secondary-container text-secondary p-2 rounded-lg">
                <span class="material-symbols-outlined">thumb_up</span>
              </div>
              <div>
                <h4 class="font-bold font-headline">Satisfaction garantie</h4>
                <p class="text-sm text-on-surface-variant">Pas satisfait ? On revient sans frais supplémentaires.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="lg:col-span-7 grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="bg-surface-container-highest p-10 rounded-2xl flex flex-col justify-between">
            <span class="material-symbols-outlined text-primary text-4xl mb-8">calendar_today</span>
            <div>
              <h3 class="text-4xl font-headline font-extrabold mb-2">7j/7</h3>
              <p class="text-on-surface-variant font-medium">Disponibilité totale pour votre planning.</p>
            </div>
          </div>
          <div class="bg-primary p-10 rounded-2xl flex flex-col justify-between text-on-primary">
            <span class="material-symbols-outlined text-4xl mb-8">speed</span>
            <div>
              <h3 class="text-4xl font-headline font-extrabold mb-2">24h</h3>
              <p class="font-medium opacity-90">Réponse garantie sous 24 heures.</p>
            </div>
          </div>
          <div class="md:col-span-2 bg-surface-container p-10 rounded-2xl flex items-center justify-between">
            <div class="flex items-center gap-6">
              <span class="material-symbols-outlined text-tertiary text-5xl">request_quote</span>
              <div>
                <h3 class="text-2xl font-headline font-extrabold mb-1">Devis gratuit</h3>
                <p class="text-on-surface-variant">Sans engagement, réponse sous 24h.</p>
              </div>
            </div>
            <a href="/contact" class="material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors">arrow_forward_ios</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-8">
    <div class="max-w-5xl mx-auto rounded-3xl bg-gradient-to-br from-primary-container to-secondary-container p-12 md:p-20 text-center relative overflow-hidden shadow-2xl">
      <div class="relative z-10 space-y-8">
        <h2 class="text-3xl md:text-5xl font-headline font-extrabold text-on-primary-container tracking-tighter">
          Prêt pour un espace impeccable ?
        </h2>
        <p class="text-on-primary-container/80 text-lg md:text-xl max-w-2xl mx-auto">
          Contactez-nous pour un devis gratuit sous 24h. Bruxelles et communes environnantes.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/contact" class="bg-on-primary-container text-primary-fixed px-10 py-5 rounded-md font-headline font-extrabold text-xl shadow-lg hover:scale-105 transition-transform">
            Demander un devis
          </a>
          <a href="https://wa.me/32488338952" target="_blank" class="bg-transparent border border-on-primary-container/20 text-on-primary-container px-10 py-5 rounded-md font-headline font-extrabold text-xl hover:bg-on-primary-container/5 transition-all">
            💚 WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

</main>

<Footer/>

</body>
</html>