---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Head from '../components/Head.astro';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <Head
    title="Nettoyage Professionnel à Bruxelles — Canapés & Vitres"
    description="AYL Cleaning — Nettoyage de canapés et de vitres à Bruxelles. Détachage, désinfection, lavage intérieur et extérieur. Intervention à domicile 7j/7. Devis gratuit — +32 488 33 89 52."
    canonical="/"
  />
</head>
<body class="bg-surface text-on-surface font-body">

<Nav currentPage="accueil"/>

<main class="relative">

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center pt-20 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-r from-white via-white/90 to-transparent z-10"></div>
      <img
        alt="Salon luxueux avec canapé et grandes fenêtres à Bruxelles"
        class="w-full h-full object-cover"
        src="https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?w=1920&q=80"
      />
    </div>
    <div class="relative z-20 max-w-7xl mx-auto px-8 w-full">
      <div class="flex flex-col justify-center space-y-8 max-w-2xl">
        <div class="space-y-4">
          <span class="text-primary font-headline font-bold uppercase tracking-[0.2em] text-sm">Nettoyage Professionnel · Bruxelles</span>
          <h1 class="text-5xl md:text-7xl font-headline font-extrabold tracking-tighter leading-none text-on-surface" style="letter-spacing: -0.02em;">
            Nettoyage canapé<br/>
            <span class="text-primary">& vitres Bruxelles</span>
          </h1>
          <p class="text-lg md:text-xl text-on-surface-variant max-w-lg font-light leading-relaxed">
            AYL Cleaning intervient à domicile à Bruxelles pour le nettoyage de vos canapés, fauteuils, fenêtres et baies vitrées. Détachage, désinfection, lavage intérieur et extérieur — résultat garanti.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a href="/contact" class="bg-gradient-to-br from-primary to-[#004d7a] text-on-primary px-8 py-4 rounded-full font-headline font-extrabold text-lg flex items-center justify-center gap-2 hover:shadow-[0_4px_24px_rgba(0,99,155,0.25)] transition-all duration-200">
            Devis gratuit
            <span class="material-symbols-outlined">arrow_forward</span>
          </a>
          <a href="tel:+32488338952" class="bg-surface-container-highest text-on-surface px-8 py-4 rounded-full font-headline font-extrabold text-lg transition-all duration-200 text-center hover:bg-surface-container-high">
            📞 +32 4 88 33 89 52
          </a>
        </div>
        <div class="pt-12 flex items-center gap-8">
          <div class="flex gap-2 text-tertiary">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
          </div>
          <p class="text-sm text-on-surface-variant font-medium">Service 5 étoiles à Bruxelles</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="bg-surface-container-low py-32 relative">
    <div class="max-w-7xl mx-auto px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
        <div class="space-y-4">
          <span class="text-primary font-headline font-bold uppercase tracking-widest text-xs">Nos expertises</span>
          <h2 class="text-4xl md:text-5xl font-headline font-extrabold tracking-tighter">Nos Services à Bruxelles</h2>
        </div>
        <p class="text-on-surface-variant max-w-sm font-light">
          Nettoyage textile et vitrerie pour particuliers et professionnels dans toutes les communes de Bruxelles.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Canapé -->
        <div class="group relative overflow-hidden bg-surface-container-lowest p-8 rounded-xl transition-all duration-500 hover:-translate-y-2 shadow-[0_4px_48px_rgba(26,28,30,0.04)]">
          <div class="relative z-10 space-y-6">
            <div class="bg-primary/10 w-16 h-16 rounded-xl flex items-center justify-center text-primary">
              <span class="material-symbols-outlined text-3xl">chair</span>
            </div>
            <div class="space-y-3">
              <h3 class="text-2xl font-headline font-bold text-on-surface">Nettoyage de canapés</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed">
                Lavage en profondeur de vos canapés, fauteuils et sièges. Détachage des taches tenaces (vin, café, urine), traitement anti-acariens, désinfection et désodorisation. Technique d'extraction à faible humidité — séchage en 2 à 4 heures.
              </p>
              <ul class="text-on-surface-variant text-sm space-y-1 mt-3">
                <li class="flex items-center gap-2"><span class="text-primary text-xs">✓</span> Tissu, microfibre, velours, cuir</li>
                <li class="flex items-center gap-2"><span class="text-primary text-xs">✓</span> Nettoyants enzymatiques biodégradables</li>
                <li class="flex items-center gap-2"><span class="text-primary text-xs">✓</span> Canapé 2 places dès 60€</li>
              </ul>
            </div>
            <div class="flex gap-3">
              <a class="flex-1 bg-surface-container text-on-surface px-4 py-3 rounded-full font-bold text-sm text-center hover:bg-surface-container-highest transition-all duration-200" href="/services/nettoyage-canape">
                En savoir plus →
              </a>
              <a class="flex-1 bg-gradient-to-br from-primary to-[#004d7a] text-on-primary px-4 py-3 rounded-full font-bold text-sm text-center hover:shadow-[0_4px_16px_rgba(0,99,155,0.2)] transition-all duration-200" href="/contact">
                Devis gratuit
              </a>
            </div>
          </div>
        </div>

        <!-- Vitres -->
        <div class="group relative overflow-hidden bg-surface-container-lowest p-8 rounded-xl transition-all duration-500 hover:-translate-y-2 shadow-[0_4px_48px_rgba(26,28,30,0.04)]">
          <div class="relative z-10 space-y-6">
            <div class="bg-primary/10 w-16 h-16 rounded-xl flex items-center justify-center text-primary">
              <span class="material-symbols-outlined text-3xl">window</span>
            </div>
            <div class="space-y-3">
              <h3 class="text-2xl font-headline font-bold text-on-surface">Nettoyage de vitres</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed">
                Lavage professionnel de vos fenêtres, baies vitrées, vérandas et vitrines. Intérieur et extérieur en une seule intervention. Nettoyant vitrerie anti-calcaire, raclette de précision et traitement hydrophobe pour un résultat sans traces durable.
              </p>
              <ul class="text-on-surface-variant text-sm space-y-1 mt-3">
                <li class="flex items-center gap-2"><span class="text-primary text-xs">✓</span> Fenêtres, baies vitrées, vérandas, châssis</li>
                <li class="flex items-center gap-2"><span class="text-primary text-xs">✓</span> Traitement anti-calcaire et hydrophobe</li>
                <li class="flex items-center gap-2"><span class="text-primary text-xs">✓</span> Appartement dès 40€</li>
              </ul>
            </div>
            <div class="flex gap-3">
              <a class="flex-1 bg-surface-container text-on-surface px-4 py-3 rounded-full font-bold text-sm text-center hover:bg-surface-container-highest transition-all duration-200" href="/services/nettoyage-vitres">
                En savoir plus →
              </a>
              <a class="flex-1 bg-gradient-to-br from-primary to-[#004d7a] text-on-primary px-4 py-3 rounded-full font-bold text-sm text-center hover:shadow-[0_4px_16px_rgba(0,99,155,0.2)] transition-all duration-200" href="/contact">
                Devis gratuit
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- POURQUOI -->
  <section class="py-32 bg-surface">
    <div class="max-w-7xl mx-auto px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
        <div class="lg:col-span-5 space-y-8">
          <h2 class="text-4xl md:text-5xl font-headline font-extrabold tracking-tighter leading-tight">
            Pourquoi choisir <span class="text-primary">AYL Cleaning ?</span>
          </h2>
          <p class="text-on-surface-variant leading-relaxed">
            Entreprise de nettoyage à domicile basée à Bruxelles, AYL Cleaning intervient chez les particuliers et les professionnels avec des produits écologiques et des techniques éprouvées. Résultat garanti ou on revient sans frais.
          </p>
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="bg-primary/10 text-primary p-2 rounded-xl">
                <span class="material-symbols-outlined">verified</span>
              </div>
              <div>
                <h4 class="font-bold font-headline text-on-surface">Techniciens expérimentés</h4>
                <p class="text-sm text-on-surface-variant">Personnel formé aux techniques de nettoyage textile et vitrerie professionnelles.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="bg-primary/10 text-primary p-2 rounded-xl">
                <span class="material-symbols-outlined">eco</span>
              </div>
              <div>
                <h4 class="font-bold font-headline text-on-surface">Produits biodégradables</h4>
                <p class="text-sm text-on-surface-variant">Nettoyants écologiques homologués, sans danger pour vos enfants, animaux et l'environnement.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="bg-primary/10 text-primary p-2 rounded-xl">
                <span class="material-symbols-outlined">thumb_up</span>
              </div>
              <div>
                <h4 class="font-bold font-headline text-on-surface">Satisfaction garantie</h4>
                <p class="text-sm text-on-surface-variant">Pas satisfait de notre prestation de nettoyage ? On revient sans frais supplémentaires.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="lg:col-span-7 grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="bg-surface-container-highest p-10 rounded-xl flex flex-col justify-between shadow-[0_4px_48px_rgba(26,28,30,0.04)]">
            <span class="material-symbols-outlined text-primary text-4xl mb-8">calendar_today</span>
            <div>
              <h3 class="text-4xl font-headline font-extrabold mb-2 text-on-surface">7j/7</h3>
              <p class="text-on-surface-variant font-medium">Disponible tous les jours de 9h à 17h.</p>
            </div>
          </div>
          <div class="bg-gradient-to-br from-primary to-[#004d7a] p-10 rounded-xl flex flex-col justify-between text-on-primary">
            <span class="material-symbols-outlined text-4xl mb-8">speed</span>
            <div>
              <h3 class="text-4xl font-headline font-extrabold mb-2">24h</h3>
              <p class="font-medium opacity-90">Réponse garantie sous 24 heures.</p>
            </div>
          </div>
          <div class="md:col-span-2 bg-surface-container-lowest p-10 rounded-xl flex items-center justify-between shadow-[0_4px_48px_rgba(26,28,30,0.04)]">
            <div class="flex items-center gap-6">
              <span class="material-symbols-outlined text-primary text-5xl">request_quote</span>
              <div>
                <h3 class="text-2xl font-headline font-extrabold mb-1 text-on-surface">Devis gratuit</h3>
                <p class="text-on-surface-variant">Sans engagement, réponse sous 24h. Appelez le +32 488 33 89 52.</p>
              </div>
            </div>
            <a href="/contact" class="material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors duration-200">arrow_forward_ios</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ZONES -->
  <section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-headline text-3xl font-extrabold mb-4 tracking-tighter">
        Zones d'intervention — <span class="text-primary">Bruxelles & communes</span>
      </h2>
      <p class="text-on-surface-variant mb-8 max-w-2xl">
        AYL Cleaning intervient dans toutes les communes de Bruxelles-Capitale pour le nettoyage de canapés et de vitres à domicile. Déplacement gratuit dans un rayon de 20km.
      </p>
      <div class="flex flex-wrap gap-3">
        {[
          { slug: 'bruxelles', label: 'Bruxelles' },
          { slug: 'anderlecht', label: 'Anderlecht' },
          { slug: 'ixelles', label: 'Ixelles' },
          { slug: 'uccle', label: 'Uccle' },
          { slug: 'etterbeek', label: 'Etterbeek' },
          { slug: 'forest', label: 'Forest' },
          { slug: 'schaerbeek', label: 'Schaerbeek' },
          { slug: 'molenbeek', label: 'Molenbeek' },
          { slug: 'saint-gilles', label: 'Saint-Gilles' },
          { slug: 'laeken', label: 'Laeken' },
        ].map(c => (
          <a href={`/zones/${c.slug}`} class="bg-surface-container-lowest text-on-surface-variant px-4 py-2 rounded-full text-sm hover:text-primary hover:bg-surface-container-highest transition-all duration-200 shadow-[0_2px_8px_rgba(26,28,30,0.06)]">
            📍 {c.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-8">
    <div class="max-w-5xl mx-auto rounded-3xl bg-gradient-to-br from-primary to-[#004d7a] p-12 md:p-20 text-center relative overflow-hidden shadow-[0_8px_48px_rgba(0,99,155,0.18)]">
      <div class="relative z-10 space-y-8">
        <h2 class="text-3xl md:text-5xl font-headline font-extrabold text-on-primary tracking-tighter" style="letter-spacing: -0.02em;">
          Canapé ou vitres à nettoyer à Bruxelles ?
        </h2>
        <p class="text-on-primary/80 text-lg md:text-xl max-w-2xl mx-auto">
          Contactez AYL Cleaning pour un devis gratuit sous 24h. Intervention à domicile dans toutes les communes de Bruxelles.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/contact" class="bg-white text-primary px-10 py-5 rounded-full font-headline font-extrabold text-xl hover:scale-105 transition-transform duration-200">
            Demander un devis
          </a>
          <a href="https://wa.me/32488338952" target="_blank" class="bg-[#25D366] text-white px-10 py-5 rounded-full font-headline font-extrabold text-xl hover:opacity-90 transition-opacity duration-200">
            💬 WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

</main>

<Footer/>

</body>
</html>