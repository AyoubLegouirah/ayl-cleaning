---
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Head from '../../components/Head.astro';
import { communes } from '../../data/communes';
import { services } from '../../data/services';

export function getStaticPaths() {
  return communes.map((commune) => ({
    params: { commune },
  }));
}

const { commune } = Astro.params;
const communeFormatted = commune.charAt(0).toUpperCase() + commune.slice(1);
---

<!DOCTYPE html>
<html class="dark" lang="fr">
<head>
  <Head title={`Nettoyage professionnel ${communeFormatted}`} description={`AYL Cleaning — Nettoyage de vitres, canapés et après travaux à ${communeFormatted}. Devis gratuit en 24h, intervention rapide.`}/>
</head>
<body class="bg-surface text-on-surface font-body">

<Nav/>

<main>

  <!-- HERO -->
  <section class="relative pt-32 pb-20 px-8 max-w-7xl mx-auto">
    <span class="text-primary uppercase tracking-[0.2em] text-xs font-bold mb-4 block">
      📍 {communeFormatted}, Bruxelles
    </span>
    <h1 class="font-headline text-5xl md:text-6xl font-extrabold text-on-surface leading-tight max-w-3xl mb-8 tracking-tighter">
      Nettoyage professionnel<br/>
      à <span class="text-primary">{communeFormatted}</span>
    </h1>
    <p class="text-on-surface-variant text-lg max-w-xl leading-relaxed mb-10">
      AYL Cleaning intervient à {communeFormatted} pour le nettoyage de vitres, canapés, bureaux et après travaux. Devis gratuit sous 24h, résultats garantis.
    </p>
    <div class="flex gap-4 flex-wrap">
      <a href="/contact" class="bg-primary text-on-primary px-8 py-4 rounded-md font-headline font-bold hover:bg-primary-container transition-all">
        Devis gratuit
      </a>
      <a href="https://wa.me/32488338952" target="_blank" class="border border-[#414751]/30 px-8 py-4 rounded-md font-headline font-bold hover:border-primary transition-all">
        💚 WhatsApp
      </a>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-7xl mx-auto">
      <span class="text-primary uppercase tracking-widest text-xs font-bold mb-4 block">Nos services à {communeFormatted}</span>
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold mb-16 tracking-tighter">
        Ce qu'on fait à {communeFormatted}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map(service => (
          <a href={`/zones/${commune}/${service.slug}`} class="group bg-surface-container rounded-xl p-8 border border-[#414751]/10 hover:border-primary/40 transition-all duration-300 hover:-translate-y-1">
            <div class="text-3xl mb-4">{service.icon}</div>
            <h3 class="font-headline text-lg font-bold text-on-surface mb-3">{service.nom}</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed mb-4">{service.description}</p>
            <span class="text-primary text-sm font-bold group-hover:underline">Voir le service →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- POURQUOI NOUS -->
  <section class="py-24 px-8 max-w-7xl mx-auto">
    <h2 class="font-headline text-3xl md:text-4xl font-extrabold mb-12 tracking-tighter">
      Pourquoi choisir AYL Cleaning à <span class="text-primary">{communeFormatted}</span> ?
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="bg-surface-container rounded-xl p-8 border border-[#414751]/10">
        <div class="text-primary text-3xl mb-4">⚡</div>
        <h3 class="font-headline font-bold text-lg mb-3">Intervention rapide</h3>
        <p class="text-on-surface-variant text-sm leading-relaxed">Nous intervenons rapidement à {communeFormatted} et dans toute la région bruxelloise. Disponible 7j/7.</p>
      </div>
      <div class="bg-surface-container rounded-xl p-8 border border-[#414751]/10">
        <div class="text-primary text-3xl mb-4">✅</div>
        <h3 class="font-headline font-bold text-lg mb-3">Résultats garantis</h3>
        <p class="text-on-surface-variant text-sm leading-relaxed">Pas satisfait de notre intervention à {communeFormatted} ? On revient sans frais supplémentaires.</p>
      </div>
      <div class="bg-surface-container rounded-xl p-8 border border-[#414751]/10">
        <div class="text-primary text-3xl mb-4">💬</div>
        <h3 class="font-headline font-bold text-lg mb-3">Devis gratuit en 24h</h3>
        <p class="text-on-surface-variant text-sm leading-relaxed">Contactez-nous pour un devis personnalisé gratuit. Réponse rapide pour tous les habitants de {communeFormatted}.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-8">
    <div class="max-w-4xl mx-auto bg-gradient-to-br from-surface-container to-surface-container-low rounded-3xl p-16 text-center border border-[#414751]/10">
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold mb-6 tracking-tighter">
        Besoin d'un nettoyage à <span class="text-primary">{communeFormatted}</span> ?
      </h2>
      <p class="text-on-surface-variant text-lg mb-10">
        Contactez AYL Cleaning pour un devis gratuit. Intervention rapide à {communeFormatted} et communes voisines.
      </p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="/contact" class="bg-primary text-on-primary px-10 py-4 rounded-md font-headline font-bold hover:bg-primary-container transition-all">
          Demander un devis
        </a>
        <a href="https://wa.me/32488338952" target="_blank" class="border border-[#414751]/30 px-10 py-4 rounded-md font-headline font-bold hover:border-primary transition-all">
          💚 WhatsApp
        </a>
      </div>
    </div>
  </section>

</main>

<Footer/>

</body>
</html>