---
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Head from '../../components/Head.astro';
import { communes } from '../../data/communes';
import { services } from '../../data/services';

export function getStaticPaths() {
  return communes.map((commune) => ({
    params: { commune: commune.slug },
    props: { commune },
  }));
}

const { commune } = Astro.props;
---

<!DOCTYPE html>
<html class="dark" lang="fr">
<head>
  <Head
    title={`Nettoyage professionnel à ${commune.nom} — AYL Cleaning`}
    description={`AYL Cleaning — Nettoyage de canapés et de vitres à ${commune.nom}. ${commune.descriptionService} Devis gratuit en 24h — 0488 33 89 52.`}
  />
</head>
<body class="bg-surface text-on-surface font-body">

<Nav/>

<main>

  <!-- HERO -->
  <section class="relative pt-32 pb-20 px-8 max-w-7xl mx-auto">
    <span class="text-primary uppercase tracking-[0.2em] text-xs font-bold mb-4 block">
      📍 {commune.nom}, Bruxelles
    </span>
    <h1 class="font-headline text-5xl md:text-6xl font-extrabold text-on-surface leading-tight max-w-3xl mb-6 tracking-tighter">
      Nettoyage professionnel<br/>
      à <span class="text-primary">{commune.nom}</span>
    </h1>
    <p class="text-on-surface-variant text-lg max-w-2xl leading-relaxed mb-10">
      {commune.descriptionService} Devis gratuit sous 24h, résultats garantis.
    </p>
    <div class="flex gap-4 flex-wrap">
      <a href="/contact" class="bg-primary text-on-primary px-8 py-4 rounded-md font-headline font-bold hover:bg-primary-container transition-all">
        Devis gratuit
      </a>
      <a href="https://wa.me/32488338952" target="_blank" class="border border-[#414751]/30 px-8 py-4 rounded-md font-headline font-bold hover:border-primary transition-all">
        💚 WhatsApp
      </a>
      <a href="tel:+32488338952" class="border border-[#414751]/30 px-8 py-4 rounded-md font-headline font-bold hover:border-primary transition-all">
        📞 0488 33 89 52
      </a>
    </div>
  </section>

  <!-- CONTEXTE LOCAL UNIQUE -->
  <section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
      <div>
        <h2 class="font-headline text-3xl font-extrabold mb-6 tracking-tighter">
          AYL Cleaning à <span class="text-primary">{commune.nom}</span>
        </h2>
        <p class="text-on-surface-variant leading-relaxed mb-6">{commune.description}</p>
        <div class="bg-surface-container rounded-xl p-6 border border-primary/20">
          <span class="material-symbols-outlined text-primary text-2xl mb-3 block">lightbulb</span>
          <p class="text-on-surface-variant text-sm leading-relaxed italic">{commune.anecdote}</p>
        </div>
      </div>
      <div class="space-y-6">
        <div class="bg-surface-container rounded-xl p-6 border border-[#414751]/10">
          <h3 class="font-headline font-bold mb-3 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-xl">location_on</span>
            Quartiers couverts
          </h3>
          <div class="flex flex-wrap gap-2">
            {commune.quartiers.map(q => (
              <span class="bg-surface-container-high text-on-surface-variant text-xs px-3 py-1 rounded-full">{q}</span>
            ))}
          </div>
        </div>
        <div class="bg-surface-container rounded-xl p-6 border border-[#414751]/10">
          <h3 class="font-headline font-bold mb-3 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-xl">home</span>
            Types de logements
          </h3>
          <p class="text-on-surface-variant text-sm">{commune.typesLogements}</p>
        </div>
        <div class="bg-surface-container rounded-xl p-6 border border-[#414751]/10">
          <h3 class="font-headline font-bold mb-3 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-xl">group</span>
            Notre clientèle à {commune.nom}
          </h3>
          <p class="text-on-surface-variant text-sm">{commune.clientele}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="py-24 px-8 max-w-7xl mx-auto">
    <span class="text-primary uppercase tracking-widest text-xs font-bold mb-4 block">Nos services à {commune.nom}</span>
    <h2 class="font-headline text-3xl md:text-4xl font-extrabold mb-12 tracking-tighter">
      Ce qu'on fait à <span class="text-primary">{commune.nom}</span>
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {services.map(service => (
        <a href={`/zones/${commune.slug}/${service.slug}`} class="group bg-surface-container rounded-xl p-8 border border-[#414751]/10 hover:border-primary/40 transition-all duration-300 hover:-translate-y-1 flex gap-6 items-start">
          <div class="text-4xl">{service.icon}</div>
          <div>
            <h3 class="font-headline text-lg font-bold text-on-surface mb-2">{service.nom} à {commune.nom}</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed mb-4">{service.description}</p>
            <span class="text-primary text-sm font-bold group-hover:underline">Voir le service →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- POURQUOI NOUS -->
  <section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-headline text-3xl font-extrabold mb-12 tracking-tighter">
        Pourquoi choisir AYL Cleaning à <span class="text-primary">{commune.nom}</span> ?
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-surface-container rounded-xl p-8 border border-[#414751]/10">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">speed</span>
          <h3 class="font-headline font-bold text-lg mb-3">Intervention rapide</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Nous connaissons bien {commune.nom} et ses accès. Disponible 7j/7 de 9h à 17h.</p>
        </div>
        <div class="bg-surface-container rounded-xl p-8 border border-[#414751]/10">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">verified</span>
          <h3 class="font-headline font-bold text-lg mb-3">Résultats garantis</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Pas satisfait de notre intervention à {commune.nom} ? On revient sans frais supplémentaires.</p>
        </div>
        <div class="bg-surface-container rounded-xl p-8 border border-[#414751]/10">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">payments</span>
          <h3 class="font-headline font-bold text-lg mb-3">Devis gratuit en 24h</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Prix fixe et transparent, sans surprise. Réponse sous 24h pour tous les habitants de {commune.nom}.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- NOS PRESTATIONS DE NETTOYAGE -->
  <section class="py-24 px-8 max-w-7xl mx-auto">
    <h2 class="font-headline text-3xl font-extrabold mb-4 tracking-tighter">
      Nos prestations de nettoyage <span class="text-primary">à {commune.nom}</span>
    </h2>
    <p class="text-on-surface-variant mb-12 max-w-2xl">
      AYL Cleaning est une entreprise de nettoyage professionnelle qui intervient à {commune.nom} pour les particuliers et les professionnels. Nos techniciens se déplacent à domicile avec tout le matériel nécessaire pour un résultat impeccable.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="bg-surface-container rounded-xl p-8 border border-[#414751]/10">
        <span class="text-3xl mb-4 block">🛋️</span>
        <h3 class="font-headline font-bold text-xl mb-4">Nettoyage de canapés à {commune.nom}</h3>
        <p class="text-on-surface-variant text-sm leading-relaxed mb-4">
          Notre service de nettoyage textile comprend le lavage en profondeur de vos canapés, fauteuils et sièges. Nous utilisons des nettoyants enzymatiques professionnels pour le détachage des taches tenaces — vin, café, urine, graisses — et un traitement désinfectant anti-acariens. Notre technique d'extraction élimine les salissures et les mauvaises odeurs incrustées dans les fibres et les rembourrages. Séchage rapide en 2 à 4 heures. Particulièrement recommandé pour les foyers avec enfants, animaux ou personnes allergiques à {commune.nom}.
        </p>
        <ul class="text-on-surface-variant text-sm space-y-2">
          <li class="flex items-center gap-2"><span class="text-primary">✓</span> Tissu, microfibre, velours, cuir, similicuir</li>
          <li class="flex items-center gap-2"><span class="text-primary">✓</span> Détachage, désinfection, désodorisation</li>
          <li class="flex items-center gap-2"><span class="text-primary">✓</span> Produits biodégradables sans résidus toxiques</li>
          <li class="flex items-center gap-2"><span class="text-primary">✓</span> Dès 60€ — devis gratuit sous 24h</li>
        </ul>
      </div>
      <div class="bg-surface-container rounded-xl p-8 border border-[#414751]/10">
        <span class="text-3xl mb-4 block">🪟</span>
        <h3 class="font-headline font-bold text-xl mb-4">Lavage de vitres à {commune.nom}</h3>
        <p class="text-on-surface-variant text-sm leading-relaxed mb-4">
          Notre service de vitrerie couvre le lavage complet de vos fenêtres, baies vitrées, vérandas et vitrines — intérieur et extérieur en une seule intervention. Nous utilisons un nettoyant vitrerie anti-calcaire professionnel, une raclette de précision et des chiffons microfibre pour un résultat sans traces ni auréoles. Les châssis, rebords et encadrements sont nettoyés dans le même passage. Un traitement hydrophobe est appliqué après le lavage pour repousser la poussière et le calcaire. Service disponible pour les particuliers, les commerces et les bureaux à {commune.nom}.
        </p>
        <ul class="text-on-surface-variant text-sm space-y-2">
          <li class="flex items-center gap-2"><span class="text-primary">✓</span> Fenêtres, baies vitrées, vérandas, châssis</li>
          <li class="flex items-center gap-2"><span class="text-primary">✓</span> Intérieur et extérieur, sans traces garanties</li>
          <li class="flex items-center gap-2"><span class="text-primary">✓</span> Traitement anti-calcaire et hydrophobe inclus</li>
          <li class="flex items-center gap-2"><span class="text-primary">✓</span> Dès 40€ — devis gratuit sous 24h</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- POURQUOI FAIRE APPEL À UN PRO -->
  <section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-headline text-3xl font-extrabold mb-4 tracking-tighter">
        Pourquoi faire appel à une <span class="text-primary">société de nettoyage professionnelle ?</span>
      </h2>
      <p class="text-on-surface-variant mb-12 max-w-2xl">
        Les produits ménagers du commerce — détergents, lessive, savon, liquide-vaisselle — ne sont pas formulés pour un nettoyage en profondeur des textiles et des surfaces vitrées. Voici pourquoi nos prestations de nettoyage font la différence.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          {
            icon: "science",
            titre: "Produits de nettoyage professionnels",
            desc: "Nos nettoyants enzymatiques et produits vitrerie concentrés sont réservés aux professionnels. Ils éliminent les salissures, désinfectent et désodorisent sans endommager les matières — là où les produits chimiques du commerce échouent ou abîment."
          },
          {
            icon: "build",
            titre: "Matériel professionnel",
            desc: "Machine d'extraction textile, raclette de précision, chiffons microfibre professionnels, pulvérisateur adapté — notre équipement garantit un résultat que les outils ménagers ne peuvent pas atteindre, même avec les meilleurs produits d'entretien."
          },
          {
            icon: "engineering",
            titre: "Techniciens formés",
            desc: "Nos nettoyeurs connaissent les techniques adaptées à chaque matière : velours, microfibre, cuir, double vitrage, véranda. Un mauvais produit ou une mauvaise méthode peut abîmer définitivement un canapé ou rayer des surfaces vitrées."
          },
          {
            icon: "schedule",
            titre: "Gain de temps et tranquillité",
            desc: "Un nettoyage professionnel complet en 45 minutes à 2 heures selon la prestation. Pas de corvée ménagère, pas de résidus, pas de déception. Nous nous occupons de tout, vous profitez du résultat immédiatement."
          },
        ].map(item => (
          <div class="bg-surface-container rounded-xl p-8 border border-[#414751]/10">
            <span class="material-symbols-outlined text-primary text-3xl mb-4 block">{item.icon}</span>
            <h3 class="font-headline font-bold text-lg mb-3">{item.titre}</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMMUNES VOISINES -->
  <section class="py-24 px-8 max-w-7xl mx-auto">
    <h2 class="font-headline text-2xl font-extrabold mb-6 tracking-tighter">
      Communes voisines de <span class="text-primary">{commune.nom}</span>
    </h2>
    <p class="text-on-surface-variant mb-6 text-sm">Nous intervenons aussi dans les communes proches :</p>
    <div class="flex flex-wrap gap-3">
      {commune.communesVoisines.map(slug => {
        const voisine = communes.find(c => c.slug === slug);
        return voisine ? (
          <a href={`/zones/${voisine.slug}`} class="bg-surface-container border border-[#414751]/10 px-4 py-2 rounded-full text-sm hover:border-primary hover:text-primary transition-all">
            📍 {voisine.nom}
          </a>
        ) : null;
      })}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-8">
    <div class="max-w-4xl mx-auto bg-gradient-to-br from-surface-container to-surface-container-low rounded-3xl p-16 text-center border border-[#414751]/10">
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold mb-4 tracking-tighter">
        Besoin d'un nettoyage à <span class="text-primary">{commune.nom}</span> ?
      </h2>
      <p class="text-on-surface-variant text-lg mb-10 max-w-xl mx-auto">
        Devis gratuit en 24h. Intervention à domicile 7j/7. Résultat garanti ou on revient sans frais.
      </p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="/contact" class="bg-primary text-on-primary px-10 py-4 rounded-md font-headline font-bold hover:bg-primary-container transition-all">
          Demander un devis gratuit
        </a>
        <a href="https://wa.me/32488338952" target="_blank" class="border border-[#414751]/30 px-10 py-4 rounded-md font-headline font-bold hover:border-primary transition-all">
          💚 WhatsApp
        </a>
        <a href="tel:+32488338952" class="border border-[#414751]/30 px-10 py-4 rounded-md font-headline font-bold hover:border-primary transition-all">
          📞 0488 33 89 52
        </a>
      </div>
    </div>
  </section>

</main>

<Footer/>

</body>
</html>