---
import type { GetStaticPaths } from 'astro';
import { services } from '../../data/services';

export const getStaticPaths = (() => {
  return services.map((service) => ({
    params: { service: service.slug },
    props: { service },
  }));
}) satisfies GetStaticPaths;

const { service } = Astro.props;
---
<!DOCTYPE html>
<html class="dark" lang="fr">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>{service.nom} à Bruxelles | AYL Cleaning</title>
<meta name="description" content={`AYL Cleaning — ${service.nom} professionnel à Bruxelles. ${service.description} Devis gratuit en 24h.`}/>
<script is:inline src="https://cdn.tailwindcss.com/3.4.1"></script>
<script is:inline>
  tailwind.config = {
    darkMode: "class",
    theme: {
      extend: {
        colors: {
          "surface": "#0f131c",
          "primary": "#a1c9ff",
          "on-primary": "#00325a",
          "primary-container": "#4494e7",
          "on-primary-container": "#002b4f",
          "secondary": "#aec8ee",
          "secondary-container": "#314a6a",
          "tertiary": "#ffb86f",
          "on-surface": "#dfe2ee",
          "on-surface-variant": "#c0c7d3",
          "surface-container": "#1c2028",
          "surface-container-low": "#181c24",
          "surface-container-high": "#262a33",
          "surface-container-highest": "#31353e",
          "surface-container-lowest": "#0a0e16",
          "outline-variant": "#414751",
        },
        fontFamily: { "headline": ["Manrope"], "body": ["Inter"] },
        borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem"},
      },
    },
  }
</script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<style is:inline>
  .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
</style>
</head>
<body class="bg-surface text-on-surface font-body">

<!-- NAV -->
<nav class="bg-[#0f131c]/70 backdrop-blur-3xl sticky top-0 z-50 border-b border-[#414751]/10">
  <div class="flex justify-between items-center w-full px-8 py-4 max-w-7xl mx-auto">
    <a href="/" class="text-2xl font-black text-[#a1c9ff] tracking-tighter font-headline">AYL</a>
    <div class="hidden md:flex gap-8 items-center font-headline font-bold">
      <a class="text-[#dfe2ee]/80 hover:text-[#a1c9ff] transition-colors" href="/">Accueil</a>
      <a class="text-[#a1c9ff] border-b-2 border-[#a1c9ff] pb-1" href="/services">Services</a>
      <a class="text-[#dfe2ee]/80 hover:text-[#a1c9ff] transition-colors" href="/contact">Contact</a>
    </div>
    <a href="/contact" class="bg-gradient-to-br from-primary to-primary-container text-on-primary px-6 py-2.5 rounded-md font-bold text-sm transition-all">
      Devis gratuit
    </a>
  </div>
</nav>

<main>

  <!-- HERO -->
  <section class="relative pt-32 pb-20 px-8 max-w-7xl mx-auto">
    <span class="text-primary uppercase tracking-[0.2em] text-xs font-bold mb-4 block">
      {service.icon} Nos services
    </span>
    <h1 class="font-headline text-5xl md:text-6xl font-extrabold text-on-surface leading-tight max-w-3xl mb-8 tracking-tighter">
      {service.nom}<br/>
      <span class="text-primary">à Bruxelles</span>
    </h1>
    <p class="text-on-surface-variant text-lg max-w-xl leading-relaxed mb-10">
      {service.description} AYL Cleaning intervient chez les particuliers et les professionnels à Bruxelles et communes environnantes.
    </p>
    <div class="flex gap-4 flex-wrap">
      <a href="/contact" class="bg-primary text-on-primary px-8 py-4 rounded-md font-headline font-bold hover:bg-primary-container transition-all">
        Devis gratuit
      </a>
      <a href="https://wa.me/32488338952" target="_blank" class="border border-[#414751]/30 px-8 py-4 rounded-md font-headline font-bold hover:border-primary transition-all">
        💚 WhatsApp
      </a>
    </div>
  </section>

  <!-- DETAILS -->
  <section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-surface-container rounded-xl p-8 border border-[#414751]/10">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">verified</span>
          <h3 class="font-headline font-bold text-lg mb-3">Résultats garantis</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Pas satisfait ? On revient sans frais. Votre satisfaction est notre priorité absolue.</p>
        </div>
        <div class="bg-surface-container rounded-xl p-8 border border-[#414751]/10">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">speed</span>
          <h3 class="font-headline font-bold text-lg mb-3">Intervention rapide</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Disponible 7j/7 de 9h à 17h. Réponse sous 24h pour tout devis.</p>
        </div>
        <div class="bg-surface-container rounded-xl p-8 border border-[#414751]/10">
          <span class="material-symbols-outlined text-primary text-3xl mb-4 block">eco</span>
          <h3 class="font-headline font-bold text-lg mb-3">Produits écologiques</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Produits professionnels sans danger pour votre famille et vos animaux.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ZONES -->
  <section class="py-24 px-8 max-w-7xl mx-auto">
    <h2 class="font-headline text-3xl font-extrabold mb-8 tracking-tighter">
      Zones d'intervention — <span class="text-primary">{service.nom}</span>
    </h2>
    <p class="text-on-surface-variant mb-8">Nous intervenons dans toutes les communes de Bruxelles :</p>
    <div class="flex flex-wrap gap-3">
      {['Bruxelles', 'Anderlecht', 'Ixelles', 'Uccle', 'Etterbeek', 'Forest', 'Schaerbeek', 'Molenbeek', 'Saint-Gilles', 'Laeken'].map(commune => (
        <a href={`/zones/${commune.toLowerCase()}`} class="bg-surface-container border border-[#414751]/10 px-4 py-2 rounded-full text-sm hover:border-primary hover:text-primary transition-all">
          📍 {commune}
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-8">
    <div class="max-w-4xl mx-auto bg-gradient-to-br from-surface-container to-surface-container-low rounded-3xl p-16 text-center border border-[#414751]/10">
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold mb-6 tracking-tighter">
        Besoin d'un <span class="text-primary">{service.nom}</span> ?
      </h2>
      <p class="text-on-surface-variant text-lg mb-10">
        Contactez AYL Cleaning pour un devis gratuit sous 24h.
      </p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="/contact" class="bg-primary text-on-primary px-10 py-4 rounded-md font-headline font-bold hover:bg-primary-container transition-all">
          Demander un devis
        </a>
        <a href="https://wa.me/32488338952" target="_blank" class="border border-[#414751]/30 px-10 py-4 rounded-md font-headline font-bold hover:border-primary transition-all">
          💚 WhatsApp
        </a>
      </div>
    </div>
  </section>

</main>

<!-- FOOTER -->
<footer class="bg-[#0a0e16] border-t border-[#414751]/10 pt-16 pb-8">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-12 px-8 max-w-7xl mx-auto text-sm text-[#dfe2ee]/60 mb-16">
    <div class="space-y-6">
      <div class="text-xl font-black text-[#a1c9ff] font-headline">AYL</div>
      <p class="leading-relaxed max-w-xs">Nettoyage professionnel à Bruxelles et communes environnantes.</p>
      <a href="https://wa.me/32488338952" target="_blank" class="inline-flex items-center gap-2 bg-[#1a472a] border border-[#2d6a44] text-[#4ade80] px-4 py-2 rounded-lg text-sm font-bold">💚 WhatsApp</a>
    </div>
    <div class="space-y-4">
      <h4 class="text-[#dfe2ee] font-bold uppercase tracking-widest text-xs">Services</h4>
      <ul class="space-y-2">
        <li><a class="hover:text-[#a1c9ff] transition-colors block" href="/services/nettoyage-vitres">Nettoyage de vitres</a></li>
        <li><a class="hover:text-[#a1c9ff] transition-colors block" href="/services/nettoyage-canape">Nettoyage de canapés</a></li>
        <li><a class="hover:text-[#a1c9ff] transition-colors block" href="/services/nettoyage-bureau">Nettoyage de bureaux</a></li>
        <li><a class="hover:text-[#a1c9ff] transition-colors block" href="/services/nettoyage-apres-travaux">Après travaux</a></li>
      </ul>
    </div>
    <div class="space-y-4">
      <h4 class="text-[#dfe2ee] font-bold uppercase tracking-widest text-xs">Navigation</h4>
      <ul class="space-y-2">
        <li><a class="hover:text-[#a1c9ff] transition-colors block" href="/">Accueil</a></li>
        <li><a class="hover:text-[#a1c9ff] transition-colors block" href="/services">Services</a></li>
        <li><a class="hover:text-[#a1c9ff] transition-colors block" href="/contact">Contact</a></li>
      </ul>
    </div>
    <div class="space-y-4">
      <h4 class="text-[#dfe2ee] font-bold uppercase tracking-widest text-xs">Contact</h4>
      <ul class="space-y-2">
        <li><a href="tel:+32488338952" class="hover:text-[#a1c9ff] transition-colors">0488 33 89 52</a></li>
        <li>Bruxelles, Belgique</li>
        <li>Lun–Dim 09:00–17:00</li>
      </ul>
    </div>
  </div>
  <div class="max-w-7xl mx-auto px-8 pt-8 border-t border-[#414751]/10 text-center text-xs text-[#dfe2ee]/30">
    <p>© 2026 AYL Cleaning · Bruxelles · Nettoyage Professionnel</p>
  </div>
</footer>

<a class="fixed bottom-8 right-8 z-[100] bg-[#25D366] text-white w-16 h-16 rounded-full flex items-center justify-center shadow-2xl hover:scale-110 transition-all" href="https://wa.me/32488338952" target="_blank">
  <svg fill="currentColor" height="32" viewBox="0 0 16 16" width="32" xmlns="http://www.w3.org/2000/svg">
    <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.898 7.898 0 0 0 13.6 2.326zM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.729.729 0 0 0-.529.247c-.182.198-.691.677-.691 1.654 0 .977.71 1.916.81 2.049.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"/>
  </svg>
</a>

</body>
</html>