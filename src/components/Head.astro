---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const {
  title,
  description = "AYL Cleaning — Nettoyage professionnel de canapés et de vitres à Bruxelles. Intervention à domicile 7j/7. Devis gratuit en 24h — +32 488 33 89 52.",
  canonical,
} = Astro.props;

const siteUrl = "https://ayl-cleaning.vercel.app";
const pageUrl = canonical ? `${siteUrl}${canonical}` : siteUrl;
const fullTitle = `${title} | AYL Cleaning Bruxelles`;

const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "AYL Cleaning",
  "description": "Nettoyage professionnel de canapés et de vitres à Bruxelles. Intervention à domicile 7j/7.",
  "url": siteUrl,
  "telephone": "+32488338952",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Bruxelles",
    "addressRegion": "Bruxelles-Capitale",
    "addressCountry": "BE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 50.8503,
    "longitude": 4.3517
  },
  "areaServed": [
    "Bruxelles", "Anderlecht", "Ixelles", "Uccle", "Etterbeek",
    "Forest", "Schaerbeek", "Molenbeek", "Saint-Gilles", "Laeken"
  ],
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
    "opens": "09:00",
    "closes": "17:00"
  },
  "priceRange": "€€",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Services de nettoyage à domicile",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Nettoyage de canapés",
          "description": "Nettoyage professionnel de canapés, fauteuils et sièges à domicile à Bruxelles."
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Nettoyage de vitres",
          "description": "Lavage professionnel de vitres, fenêtres et baies vitrées à domicile à Bruxelles."
        }
      }
    ]
  },
  "sameAs": ["https://wa.me/32488338952"]
};
---

<meta charset="utf-8"/>
<link rel="icon" type="image/x-icon" href="/favicon.ico"/>
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png"/>
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>{fullTitle}</title>
<meta name="description" content={description}/>
<link rel="canonical" href={pageUrl}/>

<!-- Open Graph -->
<meta property="og:type" content="website"/>
<meta property="og:title" content={fullTitle}/>
<meta property="og:description" content={description}/>
<meta property="og:url" content={pageUrl}/>
<meta property="og:site_name" content="AYL Cleaning"/>
<meta property="og:locale" content="fr_BE"/>
<meta property="og:image" content="https://ayl-cleaning.vercel.app/logo.png"/>

<!-- Twitter Card -->
<meta name="twitter:card" content="summary"/>
<meta name="twitter:title" content={fullTitle}/>
<meta name="twitter:description" content={description}/>
<meta name="twitter:image" content="https://ayl-cleaning.vercel.app/logo.png"/>

<!-- SEO local -->
<meta name="geo.region" content="BE-BRU"/>
<meta name="geo.placename" content="Bruxelles"/>

<!-- Schema.org LocalBusiness -->
<script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)}></script>

<script is:inline src="https://cdn.tailwindcss.com/3.4.1"></script>
<script is:inline>
  tailwind.config = {
    darkMode: "class",
    theme: {
      extend: {
        colors: {
          "surface": "#0f131c",
          "primary": "#a1c9ff",
          "on-primary": "#00325a",
          "primary-container": "#4494e7",
          "on-primary-container": "#002b4f",
          "secondary": "#aec8ee",
          "secondary-container": "#314a6a",
          "tertiary": "#ffb86f",
          "on-surface": "#dfe2ee",
          "on-surface-variant": "#c0c7d3",
          "surface-container": "#1c2028",
          "surface-container-low": "#181c24",
          "surface-container-high": "#262a33",
          "surface-container-highest": "#31353e",
          "surface-container-lowest": "#0a0e16",
          "outline-variant": "#414751",
        },
        fontFamily: { "headline": ["Manrope"], "body": ["Inter"] },
        borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem"},
      },
    },
  }
</script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<style is:inline>
  .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
</style>