---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const {
  title,
  description = "AYL Cleaning — Nettoyage professionnel de canapés et de vitres à Bruxelles et alentours. Intervention à domicile 7j/7. Devis gratuit en 24h — +32 488 33 89 52.",
  canonical,
} = Astro.props;

const siteUrl = "https://aylcleaning.be";
const pageUrl = canonical ? `${siteUrl}${canonical}` : siteUrl;
// Évite le doublon si le titre contient déjà "AYL Cleaning"
const fullTitle = title.includes("AYL Cleaning")
  ? title
  : `${title} | AYL Cleaning Bruxelles`;

const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "AYL Cleaning",
  "description": "Nettoyage professionnel de canapés et de vitres à Bruxelles et périphérie. Intervention à domicile 7j/7.",
  "url": "https://aylcleaning.be",
  "image": "https://aylcleaning.be/og-image.jpg",
  "telephone": "+32488338952",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Bruxelles",
    "addressRegion": "Bruxelles-Capitale",
    "postalCode": "1000",
    "addressCountry": "BE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 50.8503,
    "longitude": 4.3517
  },
  "areaServed": [
    "Bruxelles", "Anderlecht", "Ixelles", "Uccle", "Etterbeek",
    "Forest", "Schaerbeek", "Molenbeek", "Saint-Gilles", "Laeken",
    "Waterloo", "La Hulpe", "Rixensart", "Lasne", "Genval",
    "Vilvorde", "Zaventem", "Tervuren", "Wezembeek-Oppem",
    "Kraainem", "Dilbeek", "Grimbergen"
  ],
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
    "opens": "09:00",
    "closes": "17:00"
  },
  "priceRange": "€€",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Services de nettoyage à domicile",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Nettoyage de canapés",
          "description": "Nettoyage professionnel de canapés, fauteuils et sièges à domicile à Bruxelles et alentours."
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Nettoyage de vitres",
          "description": "Lavage professionnel de vitres, fenêtres et baies vitrées à domicile à Bruxelles et alentours."
        }
      }
    ]
  },
  "sameAs": ["https://wa.me/32488338952"]
};
---

<meta charset="utf-8"/>
<link rel="icon" type="image/x-icon" href="/favicon.ico"/>
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png"/>
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>{fullTitle}</title>
<meta name="description" content={description}/>
<meta name="robots" content="index, follow"/>
<link rel="canonical" href={pageUrl}/>

<!-- Open Graph -->
<meta property="og:type" content="website"/>
<meta property="og:title" content={fullTitle}/>
<meta property="og:description" content={description}/>
<meta property="og:url" content={pageUrl}/>
<meta property="og:site_name" content="AYL Cleaning"/>
<meta property="og:locale" content="fr_BE"/>
<meta property="og:image" content="https://aylcleaning.be/og-image.jpg"/>
<meta property="og:image:width" content="1200"/>
<meta property="og:image:height" content="630"/>
<meta property="og:image:alt" content="AYL Cleaning — Nettoyage professionnel à Bruxelles"/>

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:title" content={fullTitle}/>
<meta name="twitter:description" content={description}/>
<meta name="twitter:image" content="https://aylcleaning.be/og-image.jpg"/>

<!-- SEO local -->
<meta name="geo.region" content="BE-BRU"/>
<meta name="geo.placename" content="Bruxelles"/>

<!-- Schema.org LocalBusiness -->
<script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)}></script>

<script is:inline src="https://cdn.tailwindcss.com/3.4.1"></script>
<script is:inline>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          "surface": "#ffffff",
          "primary": "#00639b",
          "on-primary": "#ffffff",
          "primary-container": "#cce5ff",
          "on-primary-container": "#001d36",
          "secondary": "#4a6080",
          "secondary-container": "#d0e4ff",
          "on-secondary-container": "#001e31",
          "tertiary": "#7a5900",
          "on-surface": "#1a1c1e",
          "on-surface-variant": "#44474f",
          "surface-container": "#f2f4f4",
          "surface-container-low": "#f2f4f4",
          "surface-container-high": "#e8ebed",
          "surface-container-highest": "#dde4e5",
          "surface-container-lowest": "#ffffff",
          "outline-variant": "#c4c7c5",
        },
        fontFamily: { "headline": ["Manrope"], "body": ["Inter"] },
        borderRadius: {"DEFAULT": "0.5rem", "lg": "0.75rem", "xl": "1.5rem", "full": "9999px"},
      },
    },
  }
</script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<style is:inline>
  .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
</style>