---
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path || (path !== '/' && currentPath.startsWith(path));
---

<!-- Overlay semi-transparent -->
<div id="nav-overlay" aria-hidden="true"></div>

<nav id="main-nav" class="bg-white/80 backdrop-blur-[24px] sticky top-0 z-50 shadow-[0_8px_48px_0px_rgba(26,28,30,0.04)] transition-all duration-300">
  <div class="flex justify-between items-center w-full px-8 py-4 max-w-7xl mx-auto transition-all duration-300" id="nav-inner">
    <a href="/" class="flex items-center gap-1.5 font-headline font-black tracking-tighter">
      <span class="w-2 h-2 rounded-full bg-primary inline-block"></span>
      <span class="text-2xl text-primary">AYL</span>
    </a>
    <div id="nav-links" class="hidden md:flex gap-10 items-center font-headline font-bold tracking-tight relative pb-1">
      <a class={`nav-link transition-colors duration-200 ${isActive('/') ? 'text-on-surface active' : 'text-on-surface/70 hover:text-primary'}`} href="/">Accueil</a>
      <a class={`nav-link transition-colors duration-200 ${isActive('/services/nettoyage-vitres') ? 'text-on-surface active' : 'text-on-surface/70 hover:text-primary'}`} href="/services/nettoyage-vitres">Vitres</a>
      <a class={`nav-link transition-colors duration-200 ${isActive('/services/nettoyage-canape') ? 'text-on-surface active' : 'text-on-surface/70 hover:text-primary'}`} href="/services/nettoyage-canape">Canapé</a>
      <a class={`nav-link transition-colors duration-200 ${isActive('/zones-intervention') ? 'text-on-surface active' : 'text-on-surface/70 hover:text-primary'}`} href="/zones-intervention">Zones</a>
      <a class={`nav-link transition-colors duration-200 ${isActive('/contact') ? 'text-on-surface active' : 'text-on-surface/70 hover:text-primary'}`} href="/contact">Contact</a>
      <span id="nav-indicator"></span>
    </div>
    <a href="/contact" class="hidden md:inline-flex items-center gap-2 bg-gradient-to-br from-primary to-[#004d7a] text-on-primary px-6 py-2.5 rounded-full font-headline font-bold text-sm hover:shadow-[0_4px_24px_rgba(0,99,155,0.25)] transition-all duration-200 group">
      Devis gratuit
      <span class="inline-block transition-transform duration-200 group-hover:translate-x-1">→</span>
    </a>
    <button id="hamburger" class="md:hidden flex flex-col gap-1.5 p-2 relative z-10" aria-label="Menu" aria-expanded="false">
      <span class="w-6 h-0.5 bg-on-surface block"></span>
      <span class="w-6 h-0.5 bg-on-surface block"></span>
      <span class="w-6 h-0.5 bg-on-surface block"></span>
    </button>
  </div>

  <!-- Menu mobile : grid-template-rows trick pour animation hauteur fluide -->
  <div id="mobile-menu" aria-hidden="true">
    <div class="menu-inner px-8 pb-2 pt-1 flex flex-col gap-1 bg-white/97">
      <a class="menu-item font-headline font-bold text-on-surface/70 hover:text-primary py-3 border-b border-on-surface/5 transition-colors" style="--i:0" href="/">Accueil</a>
      <a class="menu-item font-headline font-bold text-on-surface/70 hover:text-primary py-3 border-b border-on-surface/5 transition-colors" style="--i:1" href="/services/nettoyage-vitres">Vitres</a>
      <a class="menu-item font-headline font-bold text-on-surface/70 hover:text-primary py-3 border-b border-on-surface/5 transition-colors" style="--i:2" href="/services/nettoyage-canape">Canapé</a>
      <a class="menu-item font-headline font-bold text-on-surface/70 hover:text-primary py-3 border-b border-on-surface/5 transition-colors" style="--i:3" href="/zones-intervention">Zones</a>
      <a class="menu-item font-headline font-bold text-on-surface/70 hover:text-primary py-3 transition-colors" style="--i:4" href="/contact">Contact</a>
      <a class="menu-item bg-gradient-to-br from-primary to-[#004d7a] text-on-primary px-6 py-2.5 rounded-full font-bold text-center mt-3" style="--i:5" href="/contact">Devis gratuit</a>
    </div>
  </div>
</nav>

<style>
  /* ─── Sliding underline indicator (desktop) ─── */
  #nav-indicator {
    position: absolute;
    bottom: 0;
    height: 2px;
    background-color: #00639b;
    border-radius: 2px;
    pointer-events: none;
    transition: left 250ms cubic-bezier(0.4, 0, 0.2, 1), width 250ms cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
  }
  #nav-indicator.visible { opacity: 1; }

  /* ─── Hamburger → ✕ ─── */
  #hamburger > span {
    transform-origin: center;
    transition: transform 220ms cubic-bezier(0.4, 0, 0.2, 1),
                opacity   180ms ease,
                width     220ms ease;
  }
  /* gap-1.5 = 6px + h-0.5 = 2px → écart centre-à-centre = 8px */
  #hamburger.open > span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
  #hamburger.open > span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  #hamburger.open > span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }

  /* ─── Menu mobile : caché sur desktop, grid trick sur mobile ─── */
  @media (min-width: 768px) {
    #mobile-menu { display: none; }
  }

  @media (max-width: 767px) {
    /* grid-template-rows trick : évite display:none → display:flex
       qui empêche toute transition CSS de hauteur */
    #mobile-menu {
      display: grid;
      grid-template-rows: 0fr;
      opacity: 0;
      transition: grid-template-rows 360ms cubic-bezier(0.4, 0, 0.2, 1),
                  opacity             300ms ease;
    }
    #mobile-menu > .menu-inner {
      overflow: hidden;
      min-height: 0; /* requis pour que grid-template-rows:0fr fonctionne */
    }
    #mobile-menu.is-open {
      grid-template-rows: 1fr;
      opacity: 1;
    }
  }

  /* ─── Apparition en cascade des items ─── */
  .menu-item {
    opacity: 0;
    transform: translateX(-14px);
    transition: opacity   260ms ease,
                transform 280ms cubic-bezier(0.4, 0, 0.2, 1);
    /* délai = temps d'ouverture court + stagger par item */
    transition-delay: calc(var(--i) * 55ms + 80ms);
  }
  #mobile-menu.is-open .menu-item {
    opacity: 1;
    transform: translateX(0);
  }
  /* Fermeture : items disparaissent rapidement, sans stagger inverse */
  #mobile-menu:not(.is-open) .menu-item {
    transition-delay: 0ms;
    transition-duration: 120ms;
  }

  /* ─── Overlay ─── */
  #nav-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
    z-index: 40; /* sous la nav (z-50) */
    opacity: 0;
    pointer-events: none;
    transition: opacity 320ms ease;
  }
  #nav-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* ─── Nav compacte au scroll ─── */
  #main-nav.scrolled  { box-shadow: 0 8px 48px 0px rgba(26,28,30,0.10); }
  #nav-inner.scrolled { padding-top: 0.625rem; padding-bottom: 0.625rem; }
</style>

<script is:inline>
  /* ── Sliding nav indicator (desktop) ── */
  const navLinks = document.getElementById('nav-links');
  const indicator = document.getElementById('nav-indicator');

  function moveIndicator(el, instant) {
    if (!navLinks || !indicator || !el) return;
    const containerRect = navLinks.getBoundingClientRect();
    const linkRect = el.getBoundingClientRect();
    if (instant) indicator.style.transition = 'none';
    indicator.style.left  = (linkRect.left - containerRect.left) + 'px';
    indicator.style.width = linkRect.width + 'px';
    indicator.classList.add('visible');
    if (instant) requestAnimationFrame(() => { indicator.style.transition = ''; });
  }

  const activeLink = navLinks?.querySelector('.nav-link.active');
  if (activeLink) moveIndicator(activeLink, true);

  navLinks?.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('mouseenter', () => moveIndicator(link, false));
  });
  navLinks?.addEventListener('mouseleave', () => {
    const active = navLinks.querySelector('.nav-link.active');
    if (active) moveIndicator(active, false);
  });

  /* ── Hamburger + menu mobile + overlay ── */
  const hamburger  = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  const overlay    = document.getElementById('nav-overlay');

  function openMenu() {
    hamburger?.classList.add('open');
    hamburger?.setAttribute('aria-expanded', 'true');
    mobileMenu?.classList.add('is-open');
    mobileMenu?.setAttribute('aria-hidden', 'false');
    overlay?.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    hamburger?.classList.remove('open');
    hamburger?.setAttribute('aria-expanded', 'false');
    mobileMenu?.classList.remove('is-open');
    mobileMenu?.setAttribute('aria-hidden', 'true');
    overlay?.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  hamburger?.addEventListener('click', () => {
    mobileMenu?.classList.contains('is-open') ? closeMenu() : openMenu();
  });

  /* Fermer en cliquant sur l'overlay */
  overlay?.addEventListener('click', closeMenu);

  /* Fermer avec Échap */
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu?.classList.contains('is-open')) closeMenu();
  });

  /* ── Nav compacte au scroll ── */
  const nav     = document.getElementById('main-nav');
  const navInner = document.getElementById('nav-inner');
  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY > 20;
    nav?.classList.toggle('scrolled', scrolled);
    navInner?.classList.toggle('scrolled', scrolled);
  }, { passive: true });
</script>
